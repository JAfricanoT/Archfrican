#!/usr/bin/env bash
# archfrican-update — bring this machine to the repo's desired state, then upgrade packages, all
# under a pre-snapshot (reversible). The promise: "updating an old Archfrican == a fresh install".
#   archfrican-update              read-only report — pre-checks + drift (changes NOTHING)
#   archfrican-update --run        full pipeline: snapshot → repo refresh → pacman -Syu → converge
#                                  (only changed modules, against a fresh DB) → AUR (reviewed)
#   archfrican-update --converge   just re-apply the repo's config/dotfiles (no package upgrade)
#   archfrican-update --prune      offer to remove Archfrican-managed pkgs no longer in the repo
#                                  (interactive; your own hand-installed packages are NEVER listed)
#   archfrican-update --no-aur     skip the AUR phase in --run
#   archfrican-update --notify     silent unless origin has new commits; sends a notification whose
#                                  "Update now" action runs --run (meant for a periodic timer)
# Never --noconfirm. Nothing is auto-removed. An AUR build failure never blocks the system upgrade.
set -uo pipefail
self="$(readlink -f "$0" 2>/dev/null || echo "$0")"
ROOT="${ARCHFRICAN_ROOT:-$(cd "$(dirname "$self")/.." && pwd)}"
# shellcheck source=/dev/null
source "$ROOT/lib/common.sh"        # ok/warn/read_pkg_list/REPO_ROOT
# shellcheck source=/dev/null
source "$ROOT/lib/converge.sh"      # drift_modules/module_hash
# shellcheck source=/dev/null
source "$ROOT/lib/manifest.sh"      # prune_candidates
# shellcheck source=/dev/null
source "$ROOT/lib/migrate.sh"       # run_migrations/pending_migrations
set +e +u +o pipefail               # interactive flow: many probes exit non-zero on the healthy path

ARCHFRICAN_REF="${ARCHFRICAN_REF:-main}"
RUN=0; CONVERGE=0; PRUNE=0; NO_AUR=0; NOTIFY=0
for a in "$@"; do case "$a" in
  --run)      RUN=1 ;;
  --converge) CONVERGE=1 ;;
  --prune)    PRUNE=1 ;;
  --no-aur)   NO_AUR=1 ;;
  --notify)   NOTIFY=1 ;;
  -h|--help)  sed -n '2,13p' "$self"; exit 0 ;;
  *) printf 'archfrican-update: unknown flag %q (see --help)\n' "$a" >&2; exit 2 ;;
esac; done

# ---------- single-instance lock ----------------------------------------------
# --run/--converge/--prune mutate shared state (git reset --hard, module .done stamps, the pacman
# DB) — two overlapping invocations corrupt any of them. The likely collision: --notify's "Update
# now" action launches a fresh --run while a manual --run (or the periodic timer's own --run) is
# already mid-flight.
#
# PID-keyed, NOT an flock'd fd: the converge phase daemonizes descendants (the theme run_after hook
# `setsid -f elephant`, elephant's clipboard watcher), which INHERIT an `exec {fd}>` lock fd and
# keep the flock held forever after archfrican-update itself exits — a genuine deadlock that needed
# a manual `rm` of the lockfile. Keying on our own PID sidesteps fd inheritance entirely: the lock
# is stale the instant this process dies, however it dies (normal, die, or SIGKILL'd mid-build).
if [ "$RUN" = 1 ] || [ "$CONVERGE" = 1 ] || [ "$PRUNE" = 1 ]; then
  LOCKDIR="${XDG_RUNTIME_DIR:-/tmp}/archfrican-update.lock.d"
  take_lock() {
    # mkdir is atomic — exactly one racing instance wins the create.
    if mkdir "$LOCKDIR" 2>/dev/null; then printf '%s\n' "$$" > "$LOCKDIR/pid"; return 0; fi
    # It exists — is the owner actually a live archfrican-update? (the cmdline check rules out a
    # PID-reuse false positive where an unrelated process now holds our old PID.)
    local op; op="$(cat "$LOCKDIR/pid" 2>/dev/null || true)"
    if [ -n "$op" ] && kill -0 "$op" 2>/dev/null \
       && tr '\0' ' ' < "/proc/$op/cmdline" 2>/dev/null | grep -q 'archfrican-update'; then
      return 1                                   # genuinely running
    fi
    rm -rf "$LOCKDIR"                            # stale (dead PID / reused) — reclaim
    if mkdir "$LOCKDIR" 2>/dev/null; then printf '%s\n' "$$" > "$LOCKDIR/pid"; return 0; fi
    return 1                                     # lost the reclaim race to another instance
  }
  take_lock || die "ya hay un archfrican-update corriendo — espera a que termine e inténtalo de nuevo"
  # Best-effort cleanup on exit; the PID staleness check above is the real guarantee if we're killed.
  trap 'rm -rf "$LOCKDIR"' EXIT
fi

warn_n=0
CHANGELOG=""    # commit subjects pulled by the last repo_refresh — see print_changelog
PRE_SNAP_NUM="" # number of the pre-update snapshot (pre_snapshot); the post-update rollback offer targets it
_ok()   { printf '  \e[32m✓\e[0m %s\n' "$*"; }
_note() { printf '  \e[33m!\e[0m %s\n' "$*"; warn_n=$((warn_n + 1)); }
_hd()   { printf '\n\e[1m  %s\e[0m\n\n' "$*"; }

# ---------- pre-update report (read-only) ------------------------------------
precheck() {
  _hd "Archfrican — chequeo previo"

  ar="$(df -BM --output=avail / 2>/dev/null | tail -1 | tr -dc 0-9)"
  if [ -n "$ar" ] && [ "$ar" -ge 3000 ]; then _ok "root: ${ar}M libres"
  else _note "poco espacio en root (${ar:-?}M) — una actualización grande puede fallar"; fi
  if mountpoint -q /boot 2>/dev/null; then
    ab="$(df -BM --output=avail /boot 2>/dev/null | tail -1 | tr -dc 0-9)"
    if [ -n "$ab" ] && [ "$ab" -ge 100 ]; then _ok "/boot: ${ab}M libres"
    else _note "/boot justo (${ab:-?}M) — elimina antes un kernel viejo"; fi
  fi

  command -v snapper >/dev/null 2>&1 \
    && _ok "snapshots activos (--run crea un pre-snapshot; snap-pac marca el -Syu)"

  if [ -f /etc/pacman.d/mirrorlist ]; then
    age=$(( ( $(date +%s) - $(stat -c %Y /etc/pacman.d/mirrorlist 2>/dev/null || echo 0) ) / 86400 ))
    if [ "$age" -le 7 ]; then _ok "mirrorlist de hace ${age}d"
    else _note "mirrorlist de hace ${age}d — --run la refresca solo (>7d) antes de actualizar"; fi
  fi

  news="$(curl -fsS --max-time 8 'https://archlinux.org/feeds/news/' 2>/dev/null \
            | grep -oE '<title>[^<]+' | sed -n '2p' | sed 's/<title>//')"
  [ -n "$news" ] && _note "última noticia de Arch: \"$news\" — lee https://archlinux.org/news/ antes de una actualización grande"

  if command -v arch-audit >/dev/null 2>&1; then
    n="$(arch-audit --quiet --upgradable 2>/dev/null | grep -c .)"
    if [ "${n:-0}" -eq 0 ]; then _ok "sin CVEs conocidos con fix disponible"
    else _note "$n paquete(s) con CVEs corregibles — esta actualización debería resolverlos"; fi
  fi

  # --- drift: is the repo behind origin? (lightweight shallow fetch) ---
  if [ -d "$ROOT/.git" ] && command -v git >/dev/null 2>&1; then
    if git -C "$ROOT" fetch --depth 1 origin "$ARCHFRICAN_REF" >/dev/null 2>&1; then
      behind="$(git -C "$ROOT" rev-list --count HEAD..FETCH_HEAD 2>/dev/null)"
      if [ "${behind:-0}" -gt 0 ]; then _note "repo: $behind commit(s) por detrás de origin/$ARCHFRICAN_REF — --run los trae"
      else _ok "repo: al día con origin/$ARCHFRICAN_REF"; fi
    fi
  fi
  # --- drift: applied modules whose on-disk inputs changed + pending migrations ---
  d="$(drift_modules 2>/dev/null | grep -c .)"
  if [ "${d:-0}" -gt 0 ]; then _note "drift de config: $d módulo(s) cambiaron en el repo — --run los re-converge"
  else _ok "config: el estado aplicado coincide con el repo"; fi
  pm="$(pending_migrations 2>/dev/null)"
  [ "${pm:-0}" -gt 0 ] && _note "$pm migración(es) pendiente(s)"

  command -v checkupdates >/dev/null 2>&1 \
    && printf '\n  %s actualización(es) de paquetes disponibles.\n' "$(checkupdates 2>/dev/null | grep -c .)"
}

# ---------- a single rollback point for the WHOLE update ----------------------
pre_snapshot() {
  command -v snapper >/dev/null 2>&1 || { _note "snapper no está — sin pre-snapshot (continuando)"; return 0; }
  local desc rev; rev="$(git -C "${ROOT:-$HOME/.archfrican}" rev-parse --short HEAD 2>/dev/null || echo '?')"
  desc="archfrican-update $(date +%Y-%m-%d) @$rev"
  # -p/--print-number returns the new snapshot's number, so the post-update validation can offer to
  # roll back to exactly THIS checkpoint if the update turns something critical red.
  if PRE_SNAP_NUM="$(sudo snapper -c root create -p -d "$desc" 2>/dev/null)" && [ -n "$PRE_SNAP_NUM" ]; then
    _ok "pre-snapshot #$PRE_SNAP_NUM creado — un reboot revierte toda la actualización"
  else PRE_SNAP_NUM=""; _note "no pude crear el pre-snapshot (continuando)"; fi
}

# After --run: did the update turn any CRITICAL check RED that wasn't red before? Only NEW reds count
# (a pre-existing red isn't this update's fault) and only reds — the expected post-update amber churn
# (kernel reboot, new updates, .pacnew) never triggers this. If so, offer the one-reboot rollback to
# the pre-snapshot. Closes the "nothing explodes" loop: the safety net is offered exactly when needed.
post_update_validate() {          # post_update_validate "<pre-update red names, newline-sep>"
  local before="$1" after new ans
  after="$("$ROOT/bin/archfrican-doctor" --red-names 2>/dev/null | sort -u)"
  new="$(printf '%s\n' "$after" | grep -Fxv -f <(printf '%s\n' "$before") 2>/dev/null | grep -v '^[[:space:]]*$' || true)"
  [ -n "$new" ] || return 0
  _hd "⚠ Posible regresión por la actualización"
  _note "chequeos que pasaron a CRÍTICO (rojo) y antes no lo estaban:"
  printf '%s\n' "$new" | sed 's/^/      • /'
  if [ -z "$PRE_SNAP_NUM" ] || ! command -v snapper >/dev/null 2>&1; then
    _note "revisa con: archfrican-doctor  (no hay pre-snapshot para revertir automáticamente)"; return 0
  fi
  _note "el pre-snapshot #$PRE_SNAP_NUM revierte TODA esta actualización en un reinicio."
  if [ -t 0 ]; then
    printf '  ¿Revertir al pre-snapshot #%s ahora? [y/N] ' "$PRE_SNAP_NUM"; read -r ans
    case "$ans" in
      y|Y) if sudo snapper -c root rollback "$PRE_SNAP_NUM"; then
             printf '  \e[32m✓ revertido.\e[0m Reinicia para volver al estado previo:  sudo systemctl reboot\n'
           else _note "el rollback falló — probá:  archfrican-rollback"; fi ;;
      *)   printf '  Ok, sin revertir. Cuando quieras:  archfrican-rollback  (o: sudo snapper -c root rollback %s)\n' "$PRE_SNAP_NUM" ;;
    esac
  else
    _note "para revertir:  archfrican-rollback   (o: sudo snapper -c root rollback $PRE_SNAP_NUM)"
  fi
}

# ---------- keep the mirrorlist fresh WITHOUT an always-on background timer --
# modules/70-hygiene.sh leaves reflector.timer off by default (it can overwrite the mirrorlist
# unattended on its own schedule). Refreshing here instead ties it to something the user actually
# asked for (--run, right before pacman -Syu uses it) — same reflector.conf, just not silent/background.
refresh_mirrors_if_stale() {
  [ "${ARCHFRICAN_SKIP_REFLECTOR:-0}" = 1 ] && { warn "mirror refresh skipped (ARCHFRICAN_SKIP_REFLECTOR=1)"; return 0; }
  command -v reflector >/dev/null 2>&1 || return 0
  [ -f /etc/pacman.d/mirrorlist ] || return 0
  local age; age=$(( ( $(date +%s) - $(stat -c %Y /etc/pacman.d/mirrorlist 2>/dev/null || echo 0) ) / 86400 ))
  [ "$age" -gt 7 ] || return 0
  _hd "Refresco de mirrors — la mirrorlist tiene ${age}d"
  if { if [ -r /etc/xdg/reflector/reflector.conf ]; then
    sudo reflector @/etc/xdg/reflector/reflector.conf
  else
    sudo reflector --protocol https --latest 20 --sort rate --age 12 --save /etc/pacman.d/mirrorlist
  fi; }; then
    _ok "mirrorlist refrescada"
  else
    _note "reflector falló — continuando con la mirrorlist actual"
  fi
}

# ---------- repo refresh + desired-state converge ----------------------------
# Split into two so --run can slot the SYSTEM UPGRADE between the pull and the module run: a module that
# installs a package newly added to a repo list must see it in a FRESH pacman DB — otherwise `pacman -S`
# fails "target not found" on a stale DB and the package silently doesn't install (the gtklock/provider
# case), only self-healing on a SECOND --run.
repo_refresh() {                 # pull the desired state + run migrations (no package changes)
  if [ -d "$ROOT/.git" ] && command -v git >/dev/null 2>&1; then
    local old new; old="$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null)"
    # depth 50, not 1: a shallow depth-1 fetch can't reconstruct the old..new commit range for the
    # changelog below (each fetch would just replace the shallow tip, discarding the history between
    # them). 50 covers any normal update gap cheaply; a gap wider than that falls back to a compare link.
    if git -C "$ROOT" fetch --depth 50 origin "$ARCHFRICAN_REF" >/dev/null 2>&1; then
      if git -C "$ROOT" reset --hard FETCH_HEAD >/dev/null 2>&1; then
        new="$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null)"
        if [ "$old" != "$new" ]; then
          _ok "repo $old → $new"
          CHANGELOG="$(git -C "$ROOT" log --no-decorate --format='%s' "$old..$new" 2>/dev/null)"
          if [ -z "$CHANGELOG" ]; then
            local url; url="$(git -C "$ROOT" remote get-url origin 2>/dev/null | sed -E 's#\.git$##')"
            CHANGELOG="(older than the local fetch depth — see ${url:-the repo}/compare/$old...$new)"
          fi
        else _ok "repo ya al día ($new)"; fi
      else _note "git reset --hard falló — convergiendo el repo local ($old) tal cual"; fi
    else _note "git fetch falló — convergiendo el repo local ($old)"; fi
  fi
  run_migrations || { _note "las migraciones fallaron — abortando antes del converge"; return 1; }
}
converge_modules() {             # run the freshly-pulled installer; only CHANGED modules re-run
  ARCHFRICAN_UPDATE=1 bash "$ROOT/install.sh" --update || { _note "el converge reportó un error — revisa arriba"; return 1; }
}
converge() {
  _hd "Converge — re-aplicar el estado deseado del repo"
  # Package installs need a FRESH pacman DB (--run syncs one between pull and converge);
  # --converge deliberately never touches pacman. If THIS pull changed a package list, a
  # module would run `pacman -S` against a stale DB — "target not found" and the package
  # silently doesn't install (the gtklock case). Refuse and point at --run instead of
  # institutionalizing a partial upgrade with a bare `pacman -Sy` here.
  local pre_rev=""
  [ -d "$ROOT/.git" ] && pre_rev="$(git -C "$ROOT" rev-parse HEAD 2>/dev/null)"
  repo_refresh || return 1
  if [ -n "$pre_rev" ]; then
    local pkg_changes
    if ! pkg_changes="$(git -C "$ROOT" diff --name-only "$pre_rev" HEAD -- packages/ flatpak/ gaming/ 2>/dev/null)"; then
      pkg_changes="(historial incompleto tras el fetch — no puedo verificar las listas; asume que cambiaron)"
    fi
    if [ -n "$pkg_changes" ]; then
      _note "este pull cambió listas de paquetes:"
      printf '%s\n' "$pkg_changes" | sed 's/^/      /'
      _note "instalar paquetes nuevos necesita la base de datos de pacman recién sincronizada"
      printf '\n  Usa:  \e[1marchfrican-update --run\e[0m  (sincroniza + actualiza + converge)\n\n'
      return 1
    fi
  fi
  converge_modules
}

# ---- what changed (conventional-commit subjects, grouped) -------------------
print_changelog() {
  [ -n "$CHANGELOG" ] || return 0
  _hd "Qué cambió"
  local feat="" fix="" other="" line type rest scope
  while IFS= read -r line; do
    [ -n "$line" ] || continue
    type="${line%%[(:]*}"                  # "feat(niri): ..." / "feat: ..." -> "feat"
    rest="${line#*: }"                     # drop the "type(scope): " / "type: " prefix
    case "$line" in
      *"("*")"*) scope="${line#*(}"; scope="${scope%%)*}"; rest="$scope: $rest" ;;   # keep the scope for context
    esac
    case "$type" in
      feat) feat="$feat    • $rest"$'\n' ;;
      fix)  fix="$fix    • $rest"$'\n' ;;
      *)    other="$other    • $line"$'\n' ;;
    esac
  done <<< "$CHANGELOG"
  [ -n "$feat" ]  && printf '  Novedades:\n%s' "$feat"
  [ -n "$fix" ]   && printf '  Arreglos:\n%s' "$fix"
  [ -n "$other" ] && printf '  Otros cambios:\n%s' "$other"
}

# ---------- desktop notification when origin has new commits -----------------
# Meant for a periodic USER timer (modules/70-hygiene.sh), not interactive use: silent when
# there's nothing new, one notification with a clickable action when there is.
do_notify() {
  { [ -d "$ROOT/.git" ] && command -v git >/dev/null 2>&1; } || exit 0
  git -C "$ROOT" fetch --depth 1 origin "$ARCHFRICAN_REF" >/dev/null 2>&1 || exit 0
  local behind; behind="$(git -C "$ROOT" rev-list --count HEAD..FETCH_HEAD 2>/dev/null)"
  [ "${behind:-0}" -gt 0 ] || exit 0
  command -v notify-send >/dev/null 2>&1 || exit 0
  # -A implies --wait: blocks until the user clicks a button, or the notification times out/closes
  # (empty/absent action either way — nothing runs). -t bounds that wait — the calling unit
  # (archfrican-update-check.service) is Type=oneshot with no timeout override, so without this the
  # DefaultTimeoutStartUSec (90s) SIGKILLs the process from outside if the user hasn't acted yet,
  # marking the unit "failed" and making archfrican-doctor report a recurring, self-inflicted AMBER.
  # The chosen action's NAME prints to stdout.
  local action
  action="$(notify-send -t 25000 -A "update=Actualizar ahora" -A "later=Más tarde" \
    "Archfrican" "$behind cambio(s) nuevo(s) disponibles. Clic para actualizar." 2>/dev/null)"
  [ "$action" = "update" ] || exit 0
  if command -v ghostty >/dev/null 2>&1; then
    ghostty -e sh -c "archfrican-update --run; printf '\n(enter para cerrar) '; read -r _"
  else
    archfrican-update --run
  fi
}

# ---------- opt-in prune (only Archfrican-managed, never your packages) -------
do_prune() {
  _hd "Prune — paquetes gestionados por Archfrican que ya no están en el repo"
  local cand ans; mapfile -t cand < <(prune_candidates)
  if [ "${#cand[@]}" -eq 0 ]; then _ok "nada que limpiar (sin paquetes gestionados sobrantes)"; return 0; fi
  printf '  Instalados por Archfrican y ya fuera de toda lista (tus propios paquetes nunca aparecen aquí):\n'
  printf '    %s\n' "${cand[@]}"
  printf '\n  ¿Eliminarlos ahora? [y/N] '; read -r ans
  case "$ans" in
    y|Y) sudo pacman -Rns "${cand[@]}" ;;   # never --noconfirm; pacman itself refuses unsafe removals
    *)   printf '  Omitido. Para eliminarlos luego:\n    sudo pacman -Rns %s\n' "${cand[*]}" ;;
  esac
}

# ---------- post-update summary ----------------------------------------------
post_summary() {
  _hd "Salud post-actualización"
  "$ROOT/bin/archfrican-doctor" 2>/dev/null || true
  print_changelog
  printf '\n  \e[32m✓ Actualización completa.\e[0m\n\n'
}

# The sharp reboot case: a kernel upgrade removed the RUNNING kernel's modules from disk (pacman
# swapped /usr/lib/modules/<old> for <new>). The running kernel can then load NO new module — veth
# (Docker networking), etc. FAIL until reboot. That's exactly what left a user's Docker/Postgres
# dead mid-task with only a vague "reboot if the kernel changed" hint. Detect it precisely (the
# running kernel's module dir is gone) and offer the reboot NOW, so "update complete" really means
# everything works. Default NO — the user may be mid-task; the choice is theirs.
reboot_if_needed() {
  [ -d "/usr/lib/modules/$(uname -r)" ] && return 0    # running kernel's modules still present → fine
  local ans
  _hd "⚠ Reinicio necesario — el kernel en ejecución se actualizó"
  _note "corres $(uname -r), pero su carpeta de módulos ya no existe (la actualización la reemplazó)."
  _note "este kernel NO puede cargar módulos nuevos (veth → Docker, etc.); servicios pueden fallar."
  _note "un reinicio arranca el kernel ya en disco y todo vuelve a la normalidad."
  if [ -t 0 ]; then
    printf '  ¿Reiniciar ahora? [y/N] '; read -r ans
    case "$ans" in
      y|Y) _note "reiniciando…"; sudo systemctl reboot ;;
      *)   printf '  Ok. Reinicia cuando puedas:  sudo systemctl reboot\n' ;;
    esac
  else
    _note "reinicia cuando puedas:  sudo systemctl reboot"
  fi
}

# ---------- dispatch ----------------------------------------------------------
if [ "$RUN" = 1 ]; then
  precheck
  # Baseline of CRITICAL (red) checks BEFORE the update, so post_update_validate flags only NEW reds
  # (a regression this run introduced), never pre-existing ones.
  before_reds="$("$ROOT/bin/archfrican-doctor" --red-names 2>/dev/null | sort -u)"
  pre_snapshot
  # Order matters: pull → UPGRADE (syncs the DB + brings the system current) → converge (installs against
  # the fresh DB) → AUR. Converging BEFORE the upgrade left a stale DB, so a package newly added to a repo
  # list failed to install ("target not found") and only self-healed on a second --run. Rollback (the
  # pre-snapshot) covers the whole sequence.
  _hd "Refresco del repo — traer el estado deseado"
  repo_refresh || exit 1
  refresh_mirrors_if_stale
  _hd "Actualización del sistema (repos oficiales) — interactiva, nunca --noconfirm"
  [ "$warn_n" -gt 0 ] && printf '  \e[33m%d aviso(s) en el chequeo previo de arriba.\e[0m\n\n' "$warn_n"
  sudo pacman -Syu || _note "pacman -Syu reportó un error — revisa arriba"
  _hd "Converge — re-aplicar el estado deseado del repo (instala contra la DB fresca)"
  converge_modules || exit 1
  if [ "$NO_AUR" = 0 ] && command -v paru >/dev/null 2>&1; then
    _hd "Actualización AUR (revisada; un build fallido nunca bloquea el sistema)"
    # with_heartbeat: un build AUR grande (rustdesk, etc.) compila en silencio muchos minutos — el
    # latido cada ~40s deja claro que sigue trabajando, no que se congeló. paru queda en primer
    # plano (sus prompts/sudo/revisión de PKGBUILD funcionan igual); la línea es solo un overlay.
    #
    # `script` graba la salida SIN romper la interactividad (asigna un PTY → paru conserva colores,
    # barras de progreso, prompts) — así, si un build falla por un conflicto de archivos, podemos
    # clasificarlo. Estos son TUS paquetes: GUIAMOS con el comando exacto y acotado, nunca pisamos
    # a ciegas (reinstalar podría reiniciar p.ej. un rustdesk activo y cortar tu sesión remota).
    aur_rc=0
    if command -v script >/dev/null 2>&1; then
      aurlog="$(mktemp)"
      with_heartbeat "actualizando paquetes AUR" script -qec 'paru -Sua' "$aurlog" || aur_rc=$?
      if [ "$aur_rc" != 0 ]; then
        aur_orph=(); aur_own=(); aur_split_conflicts "$aurlog" aur_orph aur_own
        if [ "${#aur_orph[@]}" -gt 0 ]; then
          _note "conflicto de archivo huérfano (no lo posee ningún paquete) — es SEGURO pisarlo:"
          for aur_f in "${aur_orph[@]}"; do printf '      %s\n' "$aur_f"; done
          printf '  reintenta acotado:  paru -Sua'; for aur_f in "${aur_orph[@]}"; do printf " --overwrite '%s'" "$aur_f"; done; printf '\n'
        fi
        [ "${#aur_own[@]}" -gt 0 ] && _note "conflicto con dueño (investígalo, NO lo pises a ciegas): ${aur_own[*]}"
      fi
      rm -f "$aurlog"
    else
      with_heartbeat "actualizando paquetes AUR" paru -Sua || aur_rc=$?
    fi
    [ "$aur_rc" = 0 ] || _note "falló un build de AUR — la actualización oficial ya aplicó; reintenta luego: paru -Sua"
  fi
  [ "$PRUNE" = 1 ] && do_prune
  post_summary
  post_update_validate "$before_reds"
  reboot_if_needed

elif [ "$CONVERGE" = 1 ]; then
  precheck
  pre_snapshot
  converge || exit 1
  [ "$PRUNE" = 1 ] && do_prune
  print_changelog
  printf '\n  \e[32m✓ Converge completo\e[0m — config + dotfiles coinciden con el repo (sin actualizar paquetes; para eso, --run).\n\n'

elif [ "$PRUNE" = 1 ]; then
  do_prune                                  # prune against the last recorded manifest

elif [ "$NOTIFY" = 1 ]; then
  do_notify

else
  precheck
  printf '\n  Poner esta máquina al día con el repo + actualizar paquetes:\n    \e[1marchfrican-update --run\e[0m\n'
  printf '  Re-aplicar solo config/dotfiles (sin actualizar):\n    archfrican-update --converge\n'
  printf '  Además, limpiar paquetes gestionados que ya no están:\n    archfrican-update --run --prune\n\n'
fi
