#!/usr/bin/env bash
# Hot-swap the whole desktop theme (Omarchy-style). Reloads apps live.
#   theme-switch adl-dark | adl-light | archfrican-dark | archfrican-light | catppuccin-mocha | tokyo-night | high-contrast
# Dependency-free: pure-bash/sed substitution (no envsubst/gettext needed).
set -euo pipefail
# Locate the Archfrican repo assets (themes/ + templates/). The deployed switcher is a
# symlink into the clone install.sh made at ~/.archfrican; override with ARCHFRICAN_ROOT.
ROOT="${ARCHFRICAN_ROOT:-$HOME/.archfrican}"
[ -d "$ROOT/themes" ] || {
  echo "theme assets not found under $ROOT" >&2
  echo "set ARCHFRICAN_ROOT=<archfrican repo dir>, or run install.sh to clone ~/.archfrican" >&2
  exit 1; }
THEME="${1:?usage: theme-switch <theme-name>}"
# 'dynamic' = the wallpaper-generated palette in user state (archfrican-wallpaper). It lives OUTSIDE
# themes/ on purpose, so a re-tint never changes the converge hash. Any other name is a curated theme.
if [ "$THEME" = dynamic ] && [ -r "$HOME/.config/archfrican/dynamic-colors.sh" ]; then
  PAL="$HOME/.config/archfrican/dynamic-colors.sh"
else
  PAL="$ROOT/themes/$THEME/colors.sh"
fi
[ -f "$PAL" ] || { echo "no such theme: $THEME"; echo "available:"; ls "$ROOT/themes"; exit 1; }
# ADL design tokens (fonts, radius, spacing, motion, elevation, cursor + accent-contrast fallbacks):
# the NON-colour half of the identity. Layered as a cascade — shared DEFAULTS first (base), then the
# palette (overrides defaults, e.g. each theme's own ACCENT_FG), then the theme's optional shape
# override (wins last). All share the ${TOKEN} namespace substituted below. Because the defaults are
# the base layer, the matugen 'dynamic' palette (colours only) inherits every token for free, so no
# template ${TOKEN} is ever left unrendered.
if [ -r "$ROOT/themes/tokens.defaults.sh" ]; then
  # shellcheck disable=SC1090
  source "$ROOT/themes/tokens.defaults.sh"
fi
# shellcheck disable=SC1090
source "$PAL"
if [ -r "$ROOT/themes/$THEME/tokens.sh" ]; then
  # shellcheck disable=SC1090
  source "$ROOT/themes/$THEME/tokens.sh"
fi

# Variables to substitute = exactly the ${TOKEN}s the templates use (single source
# of truth — derived, so the list can't drift or carry dead entries).
# word-split is intentional and safe: every token is a bare ${VAR} name (no spaces),
# and this stays portable to bash 3.2 (the repo avoids mapfile — cf. read_pkg_list).
# shellcheck disable=SC2207
VARS=($(grep -rhoE '\$\{[A-Za-z_][A-Za-z0-9_]*\}' "$ROOT/templates" 2>/dev/null | sed -E 's/^\$\{(.*)\}$/\1/' | sort -u || true))
[ "${#VARS[@]}" -gt 0 ] || { echo "no \${VAR} tokens found under $ROOT/templates" >&2; exit 1; }

render() {                      # render <template-name> <out-file>
  local args=() v
  for v in "${VARS[@]}"; do args+=(-e "s|\${$v}|${!v}|g"); done
  sed "${args[@]}" < "$ROOT/templates/$1" > "$2"
}

CFG="$HOME/.config"
mkdir -p "$CFG"/{ghostty,waybar,fuzzel,swaync,niri,nwg-dock}

render ghostty.colors      "$CFG/ghostty/colors"
render waybar.colors.css   "$CFG/waybar/colors.css"
render fuzzel.colors.ini   "$CFG/fuzzel/colors.ini"
render fuzzel.ini          "$CFG/fuzzel/fuzzel.ini"      # whole config (shape+spacing tokenised, not just colour)
render swaync.colors.css   "$CFG/swaync/colors.css"
render swaync.style.css    "$CFG/swaync/style.css"       # whole stylesheet (shape+elevation tokenised)
render nwg-dock.css        "$CFG/nwg-dock/style.css"
mkdir -p "$CFG/walker/themes/archfrican"                    # Walker: only the stylesheet is ours; layouts fall back to its default
render walker.css          "$CFG/walker/themes/archfrican/style.css"
mkdir -p "$CFG/gtklock" "$CFG/swaylock"
render gtklock.css         "$CFG/gtklock/style.css"       # login-styled lock (gtklock)
render swaylock.conf       "$CFG/swaylock/config"         # fallback lock
sed -i 's/=#/=/g' "$CFG/fuzzel/colors.ini" "$CFG/swaylock/config"   # fuzzel + swaylock want hex without #

# Cohesion base (always on): drive the GTK accent, system fonts and the cursor from the SAME tokens, so
# GTK/libadwaita apps — and even apps that read neither GTK nor Qt settings — wear the identity too.
# These write Archfrican-owned generated files only (chezmoi-ignored), never user content, so there is
# nothing to back up and nothing to break.
mkdir -p "$CFG/fontconfig" "$CFG/gtk-3.0" "$CFG/gtk-4.0" "$CFG/qt5ct" "$CFG/qt6ct" "$HOME/.icons/default"
render fonts.conf                "$CFG/fontconfig/fonts.conf"
render gtk.css                   "$CFG/gtk-3.0/gtk.css"
render gtk.css                   "$CFG/gtk-4.0/gtk.css"
render icons-default-index.theme "$HOME/.icons/default/index.theme"
# Qt (qt6ct/qt5ct): Fusion + the ADL icon theme. Qt6 follows the portal's dark/light on its own and
# Qt fonts come from fonts.conf above. The teal *accent* in the Qt palette (a qt6ct colorscheme or a
# Kvantum theme) is deferred to hardware validation — its colour-role order can't be checked statically.
render qt.conf                   "$CFG/qt6ct/qt6ct.conf"
render qt.conf                   "$CFG/qt5ct/qt5ct.conf"

# Cohesion Tier B (opt-in app injection): render the VS Code colour fragment to staging and the
# web-app extension's stylesheet (cheap, harmless even when off), then best-effort hand off to the
# opt-in applier so a theme switch propagates into VS Code / web-apps live. archfrican-cohesion owns
# the backup-guarded mutation of user-owned files; theme-switch itself stays pure-render.
mkdir -p "$CFG/archfrican/cohesion" "$HOME/.local/share/archfrican-webapps-ext"
render vscode.colors.json "$CFG/archfrican/cohesion/vscode.colors.json"
render webapp.css         "$HOME/.local/share/archfrican-webapps-ext/theme.css"
if [ -e "$CFG/archfrican/cohesion-on" ] && command -v archfrican-cohesion >/dev/null 2>&1; then
  archfrican-cohesion apply >/dev/null 2>&1 || true
fi

# niri: splice the themed border block between markers; niri live-reloads on save.
# GUARD (audit SEC-07): only splice when the config has BOTH markers. A config with THEME-START
# but no THEME-END would otherwise drop everything after START — silently truncating a
# hand-edited/corrupted config. The awk END-check also aborts (and we keep the original) if it
# reaches EOF still inside the block, so an out-of-order/duplicate marker can't truncate either.
if [ -f "$CFG/niri/config.kdl" ]; then
  if grep -q 'THEME-START' "$CFG/niri/config.kdl" && grep -q 'THEME-END' "$CFG/niri/config.kdl"; then
    tmpblk="$(mktemp)"; render niri.theme.kdl "$tmpblk"
    if awk 'NR==FNR{blk=blk $0 ORS; next}
         /THEME-START/{printf "%s", blk; skip=1; next}
         /THEME-END/{skip=0; next}
         !skip{print}
         END{ exit (skip ? 1 : 0) }' "$tmpblk" "$CFG/niri/config.kdl" > "$CFG/niri/config.kdl.new"; then
      mv "$CFG/niri/config.kdl.new" "$CFG/niri/config.kdl"
    else
      echo "theme-switch: niri splice aborted (unbalanced THEME markers) — left config.kdl unchanged" >&2
      rm -f "$CFG/niri/config.kdl.new"
    fi
    rm -f "$tmpblk"
  else
    echo "theme-switch: niri config has no THEME-START/THEME-END markers — skipped niri theme block (config.kdl unchanged)" >&2
  fi
fi

# SDDM login screen lives under /usr/share (the greeter runs pre-login, with no ~/.config). Update it
# best-effort: only if sudo is already cached (sudo -n never prompts), so switching themes in a session
# never blocks on a password. The authoritative render happens at install/converge (40-theming).
if [ -f "$ROOT/templates/sddm.theme.conf" ]; then
  tmp_sddm="$(mktemp)"; render sddm.theme.conf "$tmp_sddm"
  if sudo -n install -m 0644 "$tmp_sddm" /usr/share/sddm/themes/archfrican/theme.conf 2>/dev/null; then
    echo "updated the SDDM login theme"
  fi
  rm -f "$tmp_sddm"
fi

# GRUB boot menu lives under /boot (system path). GRUB reads theme.txt at boot, so a palette change shows
# next boot with NO grub-mkconfig — only the colours change; the generated .pf2 font is untouched. Same
# best-effort sudo -n as SDDM (never blocks a theme switch). Authoritative install is 40-theming.
if [ -f "$ROOT/templates/grub.theme.txt" ] && [ -d /boot/grub/themes/archfrican ]; then
  tmp_grub="$(mktemp)"; render grub.theme.txt "$tmp_grub"
  if sudo -n install -D -m 0644 "$tmp_grub" /boot/grub/themes/archfrican/theme.txt 2>/dev/null; then
    echo "updated the GRUB boot-menu theme (visible next boot)"
  fi
  rm -f "$tmp_grub"
fi

# GTK / cursors / dark-light. `timeout 5`: gsettings needs a session D-Bus — when none is reachable
# (e.g. the headless first-boot resume, no PAM/logind session) it can HANG instead of failing fast,
# and `|| true` only catches a nonzero exit, never a hang. A bounded timeout turns that into the
# fast no-op the comment already expects, instead of freezing the whole install indefinitely.
timeout 5 gsettings set org.gnome.desktop.interface color-scheme "$GTK_SCHEME" 2>/dev/null || true
timeout 5 gsettings set org.gnome.desktop.interface gtk-theme    "$GTK_THEME"  2>/dev/null || true
timeout 5 gsettings set org.gnome.desktop.interface icon-theme   "$ICON_THEME" 2>/dev/null || true
timeout 5 gsettings set org.gnome.desktop.interface font-name           "$FONT_UI $FONT_GTK_SIZE"   2>/dev/null || true
timeout 5 gsettings set org.gnome.desktop.interface monospace-font-name "$FONT_MONO $FONT_GTK_SIZE" 2>/dev/null || true
timeout 5 gsettings set org.gnome.desktop.interface cursor-theme        "$CURSOR_THEME" 2>/dev/null || true
timeout 5 gsettings set org.gnome.desktop.interface cursor-size         "$CURSOR_SIZE"  2>/dev/null || true

# live reloads (no logout)
pkill -SIGUSR2 waybar 2>/dev/null || true
swaync-client --reload-css 2>/dev/null || true
echo "$THEME" > "$CFG/.archfrican-theme"
echo "switched to $THEME"
