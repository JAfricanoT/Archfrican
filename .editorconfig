root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Repo is 2-space, tabs-free throughout (shell, bin, config).
[*.{sh,bash}]
indent_style = space
indent_size = 2

[bin/*]
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Keep bilingual Markdown line breaks intact (two trailing spaces = hard break).
[*.md]
trim_trailing_whitespace = false
