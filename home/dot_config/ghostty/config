# Archfrican · Ghostty. Colors live in ./colors (regenerated by theme-switch).
# ghostty has no font-family-fallback key — list fallbacks by repeating font-family (first = primary).
# JetBrainsMono (the ADL mono, always installed, has Nerd glyphs) primary; SF Mono if you have it.
font-family = "JetBrainsMono Nerd Font"
font-family = "SF Mono"
font-size = 13
font-feature = liga
window-padding-x = 10
window-padding-y = 10
background-opacity = 0.92
background-blur = true
cursor-style = block
mouse-hide-while-typing = true
confirm-close-surface = false
config-file = colors
