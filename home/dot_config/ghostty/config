# Archfrican · Ghostty. Colors live in ./colors (regenerated by theme-switch).
# ghostty has no font-family-fallback key — list fallbacks by repeating font-family (first = primary).
# JetBrainsMono (the ADL mono, always installed, has Nerd glyphs) primary; SF Mono if you have it.
font-family = "JetBrainsMono Nerd Font"
font-family = "SF Mono"
font-size = 13
font-feature = liga
window-padding-x = 10
window-padding-y = 10
background-opacity = 0.92
background-blur = true
cursor-style = block
mouse-hide-while-typing = true
confirm-close-surface = false

# macOS clipboard in the terminal. keyd rewrites ⌘+C/⌘+V to Ctrl+C/Ctrl+V BELOW the compositor, so
# ghostty only ever sees Ctrl+C/Ctrl+V — bind those. `performable:` consumes the key only if the action
# can run, so ⌘+C COPIES when text is selected and otherwise falls through as interrupt (SIGINT) — the
# macOS-faithful behaviour on one key. ⌘+V pastes. The defaults (Ctrl+Shift+C/V) still work too.
keybind = performable:ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard

config-file = colors
