//         color "#00000055"
//     }
//     background-effect {
//         blur true
//     }
// }
// LAYER-BLUR-END

environment {
    // Electron/Chromium apps (VS Code) -> native Wayland
    ELECTRON_OZONE_PLATFORM_HINT "wayland"
    NIXOS_OZONE_WL "1"
    // Qt / Firefox / SDL / Java on native Wayland. Set HERE, not environment.d (niri #2731).
    // Never set GDK_BACKEND globally — it breaks the screencast portal.
    QT_QPA_PLATFORM "wayland;xcb"
    QT_QPA_PLATFORMTHEME "qt6ct"
    QT_ACCESSIBILITY "1"          // expose Qt apps to the Orca screen reader
    DO_NOT_TRACK "1"              // privacy opt-out signal (honored by a growing set of tools; docs/PRIVACY.md)
    MOZ_ENABLE_WAYLAND "1"
    SDL_VIDEODRIVER "wayland"
    _JAVA_AWT_WM_NONREPARENTING "1"
    // NVIDIA-friendly defaults (harmless on AMD/Intel)
    __GL_GSYNC_ALLOWED "0"
}

// Multi-monitor: niri auto-detects + arranges outputs (hotplug included). To make a manual layout
// PERSIST: drag your monitors in `nwg-displays` (it applies live), then run `archfrican-displays save`
// — it writes your live layout between the markers below and re-applies it after every update. You can
// also hand-edit inside the markers (`niri msg outputs` for names; one block per monitor):
//   output "eDP-1" { mode "2560x1600@60.000"; scale 1.5; position x=0 y=0; variable-refresh-rate }
// ARCHFRICAN-DISPLAYS-START (managed by archfrican-displays — edit via nwg-displays + 'archfrican-displays save')
// ARCHFRICAN-DISPLAYS-END

spawn-at-startup "waybar"
spawn-at-startup "swaync"
spawn-at-startup "awww-daemon"
spawn-at-startup "{{ .chezmoi.homeDir }}/.local/bin/archfrican-wallpaper-restore"   // repose wallpaper (or solid backdrop)
spawn-at-startup "{{ .chezmoi.homeDir }}/.local/bin/archfrican-idle"   // idle + suspend screen lock
spawn-at-startup "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"
spawn-at-startup "sh" "-c" "wl-paste --watch cliphist store &"
spawn-at-startup "nwg-dock" "-d" "-i" "48"   // macOS-style dock
spawn-at-startup "swayosd-server"            // on-screen volume/brightness OSD
spawn-at-startup "nm-applet" "--indicator"   // network tray + secret agent
spawn-at-startup "udiskie" "-t"              // automount removable media (tray)
spawn-at-startup "{{ .chezmoi.homeDir }}/.local/bin/archfrican-welcome-notify"   // one-time desktop welcome (stamp-gated)

binds {
    // launchers / core
    Mod+Return        { spawn "ghostty"; }
    Mod+Space         { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-spotlight"; }   // ⌘+Space = Spotlight (apps + buscar todo)
    Mod+Tab           { toggle-overview; }         // Mission-Control-like
    Mod+Shift+Q       { close-window; }            // ⌘+W closes app tabs via keyd
    Mod+Shift+E       { quit; }
    Mod+Shift+Slash   { show-hotkey-overlay; }
    Mod+Shift+K       { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-keys"; }   // searchable key cheatsheet

    // scrolling navigation (the niri core)
    Mod+Left          { focus-column-left; }
    Mod+Right         { focus-column-right; }
    Mod+Up            { focus-window-up; }
    Mod+Down          { focus-window-down; }
    Mod+Shift+Left    { move-column-left; }
    Mod+Shift+Right   { move-column-right; }
    Mod+Shift+Up      { move-window-up; }
    Mod+Shift+Down    { move-window-down; }
    Mod+Home          { focus-column-first; }
    Mod+End           { focus-column-last; }

    // columns / sizing
    Mod+Comma         { consume-window-into-column; }
    Mod+Period        { expel-window-from-column; }
    Mod+Minus         { set-column-width "-10%"; }
    Mod+Equal         { set-column-width "+10%"; }
    Mod+Shift+F       { maximize-column; }
    Mod+Shift+M       { fullscreen-window; }
    Mod+Shift+Space   { toggle-window-floating; }

    // workspaces
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }

    // screenshots (mac: ⌘+Shift+4 region -> here Print / Mod+Shift+S)
    Print             { screenshot; }
    Mod+Shift+S       { screenshot; }
    Mod+Shift+P       { screenshot-screen; }

    // media / brightness (swayosd-client = on-screen feedback bar)
    XF86AudioRaiseVolume  { spawn "swayosd-client" "--output-volume" "raise"; }
    XF86AudioLowerVolume  { spawn "swayosd-client" "--output-volume" "lower"; }
    XF86AudioMute         { spawn "swayosd-client" "--output-volume" "mute-toggle"; }
    XF86MonBrightnessUp   { spawn "swayosd-client" "--brightness" "raise"; }
    XF86MonBrightnessDown { spawn "swayosd-client" "--brightness" "lower"; }

    // apps — Mod+Shift+<letter> never collides with keyd's plain ⌘+letter
    Mod+Shift+N { spawn "nautilus"; }                 // GUI file manager
    Mod+Shift+Y { spawn "ghostty" "-e" "yazi"; }      // TUI file manager
    Mod+Shift+B { spawn "ghostty" "-e" "btop"; }      // system monitor
    Mod+Shift+R { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-record"; }   // screen-record toggle

    // lock
    Mod+Shift+L { spawn "swaylock"; }

    // clipboard history (⌘+Shift+V) — surfaces the cliphist daemon already running at startup
    Mod+Shift+V { spawn "sh" "-c" "cliphist list | fuzzel --dmenu | cliphist decode | wl-copy"; }   // clipboard history

    // launcher command-surface (Spotlight/Raycast-style modes over fuzzel)
    Mod+Shift+A { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-actions"; }   // actions / settings hub
    Mod+Shift+W { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-window"; }    // window switcher
    Mod+Shift+C { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-calc"; }      // calculator
    Mod+Shift+G { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-find"; }      // search files

    // control center / notifications (swaync)
    Mod+Shift+D { spawn "swaync-client" "-t" "-sw"; }   // toggle control center
    Mod+Shift+T { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-layout"; }   // tiling layout picker

    // accessibility: toggle the Orca screen reader (niri exposes its UI via AccessKit)
    Mod+Alt+S { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-screenreader"; }
}
