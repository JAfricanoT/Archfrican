// ╭──────────────────────────────────────────────────────────────────────╮
// │ Archfrican · niri config — scrolling WM with macOS-friendly bindings        │
// │ Rule: the ⌘ (Mod/Super) key uses ONLY non-letter or Shift combos here,  │
// │ so it never collides with the ⌘+letter app shortcuts handled by keyd.  │
// │ Exception: Mod+W / Mod+Q — keyd (modules/20-niri-desktop.sh) leaves    │
// │ these two out of its [meta] layer on purpose, so niri owns window/app  │
// │ close semantics (guaranteed to work, unlike app-dependent Ctrl+W/Q).   │
// ╰──────────────────────────────────────────────────────────────────────╯

input {
    keyboard {
        // variant "altgr-intl" = Right Alt (AltGr) + a vowel/n gives the accent directly in ONE combo
        // (AltGr+e -> é, AltGr+n -> ñ, AltGr+1 -> ¡, AltGr+/ -> ¿ …), closer to the macOS "hold and
        // press" feel than a Compose key's tap-then-3-key-sequence. Normal typing (', ", `, ~ alone)
        // is untouched — this only overrides Right Alt combos, and "us" doesn't use AltGr for
        // anything else. Ties to the "us" layout specifically: pick a different layout via
        // archfrican-locale and this variant should be revisited (it's a us-symbols-file variant).
        xkb {
            layout "{{ output "sh" "-c" "cat ~/.config/.archfrican-kbd 2>/dev/null || echo us" | trim }}"
            variant "altgr-intl"
        }
    }
    touchpad {
        tap
        natural-scroll          // macOS-style scrolling
        dwt                     // disable-while-typing
        click-method "clickfinger"
        scroll-factor 0.6
    }
    // 3-finger swipe between columns/workspaces, like Mac spaces, is built in.
    mouse { accel-profile "flat"; }
    focus-follows-mouse max-scroll-amount="0%"
}

layout {
    gaps 12
    center-focused-column "on-overflow"
    preset-column-widths { proportion 0.33; proportion 0.5; proportion 0.67; }
    default-column-width { proportion 0.5; }

    // THEME-START (managed by theme-switch)
    focus-ring {
        width 2
        active-color "#0a84ff"
        inactive-color "#3a3a3c"
    }
    // THEME-END
}

prefer-no-csd
hotkey-overlay { skip-at-startup; }

// macOS-like frosted glass on windows. niri added blur in 26.04, but the exact
// directive is version-specific — it ships COMMENTED so an older niri can't fail
// to start. Uncomment after confirming support: `niri validate config.kdl`.
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
    // SHADOW-START — soft focus shadow (the "Archfrican window" look). Commented for the SAME
    // version-safety as blur (older niri lacks `shadow`); a fresh install's niri supports it.
    // Enable: uncomment this block, run `niri validate` to check it, then reload niri.
    // shadow {
    //     on
    //     softness 30
    //     spread 3
    //     offset x=0 y=6
    //     color "#00000055"
    // }
    // SHADOW-END
    // BLUR-START — frosted glass; OFF by default (older niri lacks it). Enable safely: `archfrican-blur on`
    // background-effect {
    //     blur true
    // }
    // BLUR-END
}

// macOS-like frosted glass on the LAUNCHER (fuzzel) — a layer-shell surface, so blur + shadow come from a
// layer-rule. LAUNCHER ONLY: niri's layer blur covers the ENTIRE layer surface (it can't clip to just the
// visible card yet — that needs the ext-background-effect protocol), so blurring swaync's large
// control-center / notification layers would flatten the whole screen behind them. The control center stays
// a clean translucent panel via its own CSS; for the launcher this whole-layer blur is the wanted Spotlight
// focus effect. Shipped OFF for version-safety (older niri lacks blur); enable with: archfrican-blur on
// (Multi-line blocks on purpose: single-line nested KDL silently breaks niri.)
// LAYER-BLUR-START
// layer-rule {
//     match namespace="^launcher$"
//     geometry-corner-radius 16
//     shadow {
//         on
//         softness 30
//         spread 3
//         offset x=0 y=6
//         color "#00000055"
//     }
//     background-effect {
//         blur true
//     }
// }
// LAYER-BLUR-END

environment {
    // Electron/Chromium apps (VS Code) -> native Wayland
    ELECTRON_OZONE_PLATFORM_HINT "wayland"
    NIXOS_OZONE_WL "1"
    // Qt / Firefox / SDL / Java on native Wayland. Set HERE, not environment.d (niri #2731).
    // Never set GDK_BACKEND globally — it breaks the screencast portal.
    QT_QPA_PLATFORM "wayland;xcb"
    QT_QPA_PLATFORMTHEME "qt6ct"
    QT_ACCESSIBILITY "1"          // expose Qt apps to the Orca screen reader
    DO_NOT_TRACK "1"              // privacy opt-out signal (honored by a growing set of tools; docs/PRIVACY.md)
    MOZ_ENABLE_WAYLAND "1"
    SDL_VIDEODRIVER "wayland"
    _JAVA_AWT_WM_NONREPARENTING "1"
    // NVIDIA-friendly defaults (harmless on AMD/Intel)
    __GL_GSYNC_ALLOWED "0"
}

// Multi-monitor: niri auto-detects + arranges outputs (hotplug included). To make a manual layout
// PERSIST: drag your monitors in `nwg-displays` (it applies live), then run `archfrican-displays save`
// — it writes your live layout between the markers below and re-applies it after every update. You can
// also hand-edit inside the markers (`niri msg outputs` for names; one block per monitor):
//   output "eDP-1" { mode "2560x1600@60.000"; scale 1.5; position x=0 y=0; variable-refresh-rate }
// ARCHFRICAN-DISPLAYS-START (managed by archfrican-displays — edit via nwg-displays + 'archfrican-displays save')
// ARCHFRICAN-DISPLAYS-END

spawn-at-startup "waybar"
spawn-at-startup "swaync"
spawn-at-startup "elephant"                          // Walker's backend data daemon (must run in the session env)
spawn-at-startup "walker" "--gapplication-service"   // launcher service → instant ⌘+Space (archfrican-spotlight)
spawn-at-startup "awww-daemon"
spawn-at-startup "{{ .chezmoi.homeDir }}/.local/bin/archfrican-wallpaper-restore"   // repose wallpaper (or solid backdrop)
spawn-at-startup "{{ .chezmoi.homeDir }}/.local/bin/archfrican-idle"   // idle + suspend screen lock
spawn-at-startup "/usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1"
spawn-at-startup "sh" "-c" "wl-paste --watch cliphist store &"
spawn-at-startup "nwg-dock" "-d" "-i" "48"   // macOS-style dock
spawn-at-startup "swayosd-server"            // on-screen volume/brightness OSD
spawn-at-startup "nm-applet" "--indicator"   // network tray + secret agent
spawn-at-startup "udiskie" "-t"              // automount removable media (tray)
spawn-at-startup "{{ .chezmoi.homeDir }}/.local/bin/archfrican-welcome-notify"   // one-time desktop welcome (stamp-gated)

binds {
    // Lanzadores y núcleo
    Mod+Return        { spawn "ghostty"; }             // abrir terminal
    Mod+Space         { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-spotlight"; }   // ⌘+Space = Spotlight (apps + buscar todo)
    Mod+Tab           { toggle-overview; }         // Mission-Control-like
    Mod+W             { close-window; }            // ⌘+W closes ONE window
    Mod+Q             { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-quit-app"; }   // ⌘+Q closes ALL windows of the app
    Mod+Shift+E       { quit; }                    // cerrar sesión de niri
    Mod+Shift+Slash   { show-hotkey-overlay; }      // resumen nativo de niri, sin buscador (compara con ⌘+Shift+K)
    Mod+Shift+K       { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-keys"; }   // searchable key cheatsheet

    // nota: arriba/abajo caen a cambio de espacio en los extremos de una columna, igual que izquierda/derecha
    // Navegación entre columnas
    Mod+Left          { focus-column-left; }   // enfocar columna a la izquierda
    Mod+Right         { focus-column-right; }   // enfocar columna a la derecha
    Mod+Up            { focus-window-or-workspace-up; }   // enfocar ventana arriba (o espacio anterior)
    Mod+Down          { focus-window-or-workspace-down; }   // enfocar ventana abajo (o espacio siguiente)
    Mod+Shift+Left    { move-column-left; }   // mover columna a la izquierda
    Mod+Shift+Right   { move-column-right; }   // mover columna a la derecha
    Mod+Shift+Up      { move-window-up-or-to-workspace-up; }   // mover ventana arriba (o al espacio anterior)
    Mod+Shift+Down    { move-window-down-or-to-workspace-down; }   // mover ventana abajo (o al espacio siguiente)
    Mod+Home          { focus-column-first; }   // enfocar primera columna
    Mod+End           { focus-column-last; }   // enfocar última columna

    // Monitores (multimonitor)
    Mod+Ctrl+Left          { focus-monitor-left; }   // enfocar el monitor de la izquierda
    Mod+Ctrl+Right         { focus-monitor-right; }   // enfocar el monitor de la derecha
    Mod+Ctrl+Up            { focus-monitor-up; }   // enfocar el monitor de arriba
    Mod+Ctrl+Down          { focus-monitor-down; }   // enfocar el monitor de abajo
    Mod+Ctrl+Shift+Left    { move-column-to-monitor-left; }   // mover columna al monitor de la izquierda
    Mod+Ctrl+Shift+Right   { move-column-to-monitor-right; }   // mover columna al monitor de la derecha
    Mod+Ctrl+Shift+Up      { move-column-to-monitor-up; }   // mover columna al monitor de arriba
    Mod+Ctrl+Shift+Down    { move-column-to-monitor-down; }   // mover columna al monitor de abajo
    Mod+Ctrl+Alt+Left      { move-workspace-to-monitor-left; }   // mover el espacio completo al monitor de la izquierda
    Mod+Ctrl+Alt+Right     { move-workspace-to-monitor-right; }   // mover el espacio completo al monitor de la derecha
    Mod+Ctrl+Alt+Up        { move-workspace-to-monitor-up; }   // mover el espacio completo al monitor de arriba
    Mod+Ctrl+Alt+Down      { move-workspace-to-monitor-down; }   // mover el espacio completo al monitor de abajo

    // Columnas: tamaño y modos
    Mod+Comma         { consume-window-into-column; }   // meter ventana en la columna
    Mod+Period        { expel-window-from-column; }   // sacar ventana de la columna
    Mod+Minus         { set-column-width "-10%"; }   // encoger columna
    Mod+Equal         { set-column-width "+10%"; }   // agrandar columna
    Mod+Shift+F       { maximize-column; }   // maximizar columna
    Mod+Shift+M       { fullscreen-window; }   // pantalla completa
    Mod+Shift+Space   { toggle-window-floating; }   // ventana flotante on/off

    // Espacios de trabajo
    Mod+1 { focus-workspace 1; }   // ir al espacio 1
    Mod+2 { focus-workspace 2; }   // ir al espacio 2
    Mod+3 { focus-workspace 3; }   // ir al espacio 3
    Mod+4 { focus-workspace 4; }   // ir al espacio 4
    Mod+5 { focus-workspace 5; }   // ir al espacio 5
    Mod+Shift+1 { move-column-to-workspace 1; }   // mover columna al espacio 1
    Mod+Shift+2 { move-column-to-workspace 2; }   // mover columna al espacio 2
    Mod+Shift+3 { move-column-to-workspace 3; }   // mover columna al espacio 3

    // Capturas de pantalla
    Print             { screenshot; }   // captura de región
    Mod+Shift+S       { screenshot; }   // captura de región
    Mod+Shift+P       { screenshot-screen; }   // captura de toda la pantalla

    // nota: swayosd-client muestra una barra visual en pantalla con el nuevo valor
    // Media y brillo
    XF86AudioRaiseVolume  { spawn "swayosd-client" "--output-volume" "raise"; }   // subir volumen
    XF86AudioLowerVolume  { spawn "swayosd-client" "--output-volume" "lower"; }   // bajar volumen
    XF86AudioMute         { spawn "swayosd-client" "--output-volume" "mute-toggle"; }   // silenciar / activar sonido
    XF86MonBrightnessUp   { spawn "swayosd-client" "--brightness" "raise"; }   // subir brillo
    XF86MonBrightnessDown { spawn "swayosd-client" "--brightness" "lower"; }   // bajar brillo

    // nota: Mod+Shift+<letra> llega a niri porque la capa [meta+shift] de keyd la deja pasar como
    // nota: Super+Shift+<letra> (la capa [meta] de ⌘+letra la capturaría si no) — ver 20-niri-desktop.sh
    // Apps rápidas
    Mod+Shift+N { spawn "nautilus"; }                 // GUI file manager
    Mod+Shift+Y { spawn "ghostty" "-e" "yazi"; }      // TUI file manager
    Mod+Shift+B { spawn "ghostty" "-e" "btop"; }      // system monitor
    Mod+Shift+R { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-record"; }   // screen-record toggle

    // Bloqueo de pantalla
    Mod+Shift+L { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-lock"; }   // bloquear sesión

    // nota: surge del daemon cliphist ya iniciado al arrancar
    // Portapapeles
    Mod+Shift+V { spawn "sh" "-c" "cliphist list | fuzzel --dmenu | cliphist decode | wl-copy"; }   // clipboard history

    // Buscadores y paneles
    Mod+Shift+A { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-actions"; }   // actions / settings hub
    Mod+Shift+W { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-window"; }    // window switcher
    Mod+Shift+C { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-calc"; }      // calculator
    Mod+Shift+G { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-find"; }      // search files

    // Centro de control y diseño
    Mod+Shift+D { spawn "swaync-client" "-t" "-sw"; }   // toggle control center
    Mod+Shift+T { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-layout"; }   // tiling layout picker

    // Accesibilidad
    Mod+Alt+S { spawn "{{ .chezmoi.homeDir }}/.local/bin/archfrican-screenreader"; }   // activar/desactivar lector de pantalla Orca
}
