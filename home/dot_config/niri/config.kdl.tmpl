// ╭──────────────────────────────────────────────────────────────────────╮
// │ Archfrican · niri config — scrolling WM with macOS-friendly bindings        │
// │ Rule: the ⌘ (Mod/Super) key uses ONLY non-letter or Shift combos here,  │
// │ so it never collides with the ⌘+letter app shortcuts handled by keyd.  │
// ╰──────────────────────────────────────────────────────────────────────╯

input {
    keyboard {
        xkb { layout "{{ output "sh" "-c" "cat ~/.config/.archfrican-kbd 2>/dev/null || echo us" | trim }}"; }
    }
    touchpad {
        tap
        natural-scroll          // macOS-style scrolling
        dwt                     // disable-while-typing
        click-method "clickfinger"
        scroll-factor 0.6
    }
    // 3-finger swipe between columns/workspaces, like Mac spaces, is built in.
    mouse { accel-profile "flat"; }
    focus-follows-mouse max-scroll-amount="0%"
}

layout {
    gaps 12
    center-focused-column "on-overflow"
    preset-column-widths { proportion 0.33; proportion 0.5; proportion 0.67; }
    default-column-width { proportion 0.5; }

    // THEME-START (managed by theme-switch)
    focus-ring {
        width 2
        active-color "#0a84ff"
        inactive-color "#3a3a3c"
    }
    // THEME-END
}

prefer-no-csd
hotkey-overlay { skip-at-startup; }

// macOS-like frosted glass on windows. niri added blur in 26.04, but the exact
// directive is version-specific — it ships COMMENTED so an older niri can't fail
// to start. Uncomment after confirming support: `niri validate config.kdl`.
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
    // SHADOW-START — soft focus shadow (the "Archfrican window" look). Commented for the SAME
    // version-safety as blur (older niri lacks `shadow`); a fresh install's niri supports it.
    // Enable: uncomment this block, run `niri validate` to check it, then reload niri.
    // shadow {
    //     on
    //     softness 30
    //     spread 3
    //     offset x=0 y=6
    //     color "#00000055"
    // }
    // SHADOW-END
    // BLUR-START — frosted glass; OFF by default (older niri lacks it). Enable safely: `archfrican-blur on`
    // background-effect {
    //     blur true
    // }
    // BLUR-END
}

// macOS-like frosted glass on the LAUNCHER (fuzzel) + CONTROL CENTER / notifications (swaync). These are
// layer-shell surfaces, so blur + shadow come from layer-rule (not the window-rule above). Shipped OFF for
// the SAME version-safety as window blur (an older niri lacks layer blur/shadow and would refuse to start).
// Enable everything together — validated and auto-reverted if niri is too old — with:  archfrican-blur on
// (Multi-line blocks on purpose: single-line nested KDL silently breaks niri.)
// LAYER-BLUR-START
// layer-rule {
