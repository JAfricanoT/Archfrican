#!/usr/bin/env bash
# archfrican-defaults — set default apps the macOS way, but USEFUL: per category it shows only the
# RELEVANT apps — the ones you have installed, PLUS "⤓ Instalar X…" for the common ones you don't —
# and reassigns all of that category's url/mime handlers at once. "Otra app instalada…" is the escape
# hatch to the full list. xdg-utils + pacman/paru/flatpak; installs run in a ghostty terminal.
set -euo pipefail
have() { command -v "$1" >/dev/null 2>&1; }
have fuzzel || { echo "fuzzel required" >&2; exit 1; }
note() { have notify-send && notify-send "Archfrican" "$1" || echo "$1"; }
APPDIRS=(/usr/share/applications "$HOME/.local/share/applications" \
         /var/lib/flatpak/exports/share/applications "$HOME/.local/share/flatpak/exports/share/applications")

have_desktop() { local id="$1" d; for d in "${APPDIRS[@]}"; do [ -e "$d/$id" ] && return 0; done; return 1; }
is_installed() { if [ "$1" = cli ]; then have "$2"; else have_desktop "$2"; fi; }   # CLI tool (cmd) vs GUI app (.desktop)

list_apps() {   # "Name<TAB>id.desktop" for every visible app — the fallback ("Otra app instalada…")
  local d f name
  for d in "${APPDIRS[@]}"; do
    [ -d "$d" ] || continue
    for f in "$d"/*.desktop; do
      [ -e "$f" ] || continue
      grep -qi '^NoDisplay=true' "$f" && continue
      name="$(sed -n 's/^Name=//p' "$f" | head -1)"
      printf '%s\t%s\n' "${name:-$(basename "$f" .desktop)}" "$(basename "$f")"
    done
  done | sort -u
}

do_install() {  # do_install <spec> ; spec = repo:pkgs | aur:pkgs | flatpak:appid | script:url (in a terminal)
  local kind="${1%%:*}" pkg="${1#*:}"
  case "$kind" in
    repo)    ghostty -e sh -c "sudo pacman -S --needed -- $pkg; printf '\n(enter para cerrar) '; read -r _" ;;
    aur)     if have paru; then ghostty -e sh -c "paru -S --needed -- $pkg; printf '\n(enter para cerrar) '; read -r _"
             else note "paru (AUR) no disponible"; return 1; fi ;;
    flatpak) if have flatpak; then ghostty -e sh -c "flatpak install -y flathub $pkg; printf '\n(enter para cerrar) '; read -r _"
             else note "flatpak no disponible"; return 1; fi ;;
    # Vendors' official one-line installer (e.g. Claude Code) — more reliable than the flaky AUR
    # wrappers for fast-moving AI CLIs. URL is hardcoded in the table, never user input.
    script)  if have curl; then ghostty -e sh -c "curl -fsSL '$pkg' | bash; printf '\n(enter para cerrar) '; read -r _"
             else note "curl no disponible"; return 1; fi ;;
    *) return 1 ;;
  esac
}

apply_default() {  # apply_default <desktop-id> <how> [mime...] ; how = browser | mime | terminal
  local id="$1" how="$2"; shift 2
  case "$how" in
    terminal) mkdir -p "$HOME/.config"; printf '%s\n' "$id" > "$HOME/.config/xdg-terminals.list" ;;
    browser)  if have xdg-settings; then xdg-settings set default-web-browser "$id" 2>/dev/null || true; fi
              for m in "$@"; do xdg-mime default "$id" "$m"; done ;;
    mime)     for m in "$@"; do xdg-mime default "$id" "$m"; done ;;
  esac
}

# category <prompt> <how> <mimes-space-separated> <"Display|desktop-id|install-spec"...>
category() {
  local prompt="$1" how="$2" targets="$3"; shift 3
  local rows=("$@") entries=() row disp id spec sel want
  local tgt=(); [ -n "$targets" ] && read -r -a tgt <<<"$targets"
  for row in "${rows[@]}"; do
    IFS='|' read -r disp id spec <<<"$row"
    if is_installed "$how" "$id"; then entries+=("$disp"); else entries+=("⤓ Instalar $disp…"); fi
  done
  [ "$how" = cli ] || entries+=("Otra app instalada…")   # CLIs have no .desktop list to fall back to
  sel="$(printf '%s\n' "${entries[@]}" | fuzzel --dmenu --prompt "$prompt ")" || return 0
  [ -n "$sel" ] || return 0
  if [ "$sel" = "Otra app instalada…" ]; then
    id="$(list_apps | fuzzel --dmenu --prompt "$prompt " | cut -f2)"; [ -n "$id" ] || return 0
    apply_default "$id" "$how" ${tgt[@]+"${tgt[@]}"}; note "Por defecto: $id"; return 0
  fi
  want="${sel#⤓ Instalar }"; want="${want%…}"
  for row in "${rows[@]}"; do
    IFS='|' read -r disp id spec <<<"$row"
    [ "$disp" = "$want" ] || continue
    if ! is_installed "$how" "$id"; then
      do_install "$spec" || return 0
      is_installed "$how" "$id" || { note "$disp no quedó instalado"; return 0; }
    fi
    if [ "$how" = cli ]; then note "$disp listo ✓"
    else apply_default "$id" "$how" ${tgt[@]+"${tgt[@]}"}; note "Por defecto: $disp"; fi
    return 0
  done
}

cat="$(printf '%s\n' \
  "Navegador web" "Editor / IDE" "IA / agentes (CLI)" "Terminal" "Gestor de archivos" \
  "Visor de PDF" "Visor de imágenes" "Correo" \
  | fuzzel --dmenu --prompt '  app por defecto  ')" || exit 0

case "$cat" in
  "Navegador web")
    category '  navegador  ' browser 'x-scheme-handler/http x-scheme-handler/https text/html' \
      "Firefox|firefox.desktop|repo:firefox" \
      "Brave|brave-browser.desktop|aur:brave-bin" \
      "Chromium|chromium.desktop|repo:chromium" \
      "Vivaldi|vivaldi-stable.desktop|aur:vivaldi" \
      "Mullvad Browser|mullvad-browser.desktop|aur:mullvad-browser-bin" ;;
  "Editor / IDE")
    category '  editor  ' mime 'text/plain text/markdown application/json text/x-csrc text/x-c++src text/x-python application/x-shellscript text/x-java' \
      "VS Code (OSS)|code-oss.desktop|repo:code" \
      "Zed|dev.zed.Zed.desktop|repo:zed" \
      "Neovim (terminal)|nvim.desktop|repo:neovim" \
      "Gnome Text Editor|org.gnome.TextEditor.desktop|repo:gnome-text-editor" \
      "Kate|org.kde.kate.desktop|repo:kate" \
      "Cursor|cursor.desktop|aur:cursor-bin" \
      "Antigravity|antigravity.desktop|aur:antigravity-ide" ;;
  "IA / agentes (CLI)")
    category '  IA (CLI)  ' cli '' \
      "Claude Code|claude|script:https://claude.ai/install.sh" \
      "OpenCode|opencode|aur:opencode-bin" \
      "Gemini CLI|gemini|aur:gemini-cli-git" \
      "Aider|aider|aur:aider-chat" \
      "Codex CLI|codex|aur:openai-codex-bin" ;;
  "Terminal")
    category '  terminal  ' terminal '' \
      "Ghostty|com.mitchellh.ghostty.desktop|repo:ghostty" \
      "Kitty|kitty.desktop|repo:kitty" \
      "Alacritty|Alacritty.desktop|repo:alacritty" \
      "foot|foot.desktop|repo:foot" ;;
  "Gestor de archivos")
    category '  archivos  ' mime 'inode/directory' \
      "Nautilus (Files)|org.gnome.Nautilus.desktop|repo:nautilus" \
      "Dolphin|org.kde.dolphin.desktop|repo:dolphin" \
      "Thunar|thunar.desktop|repo:thunar" \
      "Nemo|nemo.desktop|repo:nemo" ;;
  "Visor de PDF")
    category '  PDF  ' mime 'application/pdf' \
      "Papers / Evince|org.gnome.Evince.desktop|repo:evince" \
      "Okular|org.kde.okular.desktop|repo:okular" \
      "Zathura|org.pwmt.zathura.desktop|repo:zathura zathura-pdf-mupdf" ;;
  "Visor de imágenes")
    category '  imágenes  ' mime 'image/png image/jpeg image/gif image/webp image/svg+xml image/tiff image/bmp' \
      "Loupe|org.gnome.Loupe.desktop|repo:loupe" \
      "Image Viewer (eog)|org.gnome.eog.desktop|repo:eog" \
      "gThumb|org.gnome.gThumb.desktop|repo:gthumb" \
      "imv|imv.desktop|repo:imv" ;;
  "Correo")
    category '  correo  ' mime 'x-scheme-handler/mailto' \
      "Thunderbird|thunderbird.desktop|repo:thunderbird" \
      "Geary|org.gnome.Geary.desktop|repo:geary" \
      "Evolution|org.gnome.Evolution.desktop|repo:evolution" ;;
esac
