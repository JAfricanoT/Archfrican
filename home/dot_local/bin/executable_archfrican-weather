#!/usr/bin/env bash
# archfrican-weather — wttr.in weather pill for waybar
# City resolution priority:
#   1. ~/.config/archfrican/weather contains an explicit city name  → use it
#   2. file contains "auto"  OR  file absent                        → derive from system timezone
#   3. file contains "off"                                          → hide the module
# Examples:
#   echo "off"         > ~/.config/archfrican/weather   # disable
#   echo "auto"        > ~/.config/archfrican/weather   # timezone-based (default)
#   echo "Buenos Aires"> ~/.config/archfrican/weather   # explicit city
CONF="${XDG_CONFIG_HOME:-$HOME/.config}/archfrican/weather"

# Explicit opt-out
if [ -f "$CONF" ] && [ "$(cat "$CONF" | tr -d '[:space:]')" = off ]; then
    printf '{"text":"","class":"hidden"}\n'; exit 0
fi

# City: explicit name > timezone-derived
if [ -f "$CONF" ]; then
    _val=$(cat "$CONF" | tr -d '[:space:]')
else
    _val=auto
fi

if [ "$_val" != auto ]; then
    city="$_val"
else
    # /etc/localtime → .../zoneinfo/America/Caracas → city = Caracas
    tz=$(readlink -f /etc/localtime 2>/dev/null | sed 's|.*/zoneinfo/||')
    [ -z "$tz" ] && tz=$(timedatectl show 2>/dev/null | sed -n 's/^Timezone=//p')
    city="${tz##*/}"     # strip continent  (America/Caracas → Caracas)
    city="${city//_/ }"  # underscores → spaces (New_York → New York)
fi

enc="${city// /+}"

CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/archfrican/weather.json"
AGE=1800
mkdir -p "$(dirname "$CACHE")"

if [ -f "$CACHE" ] && [ $(( $(date +%s) - $(stat -c %Y "$CACHE" 2>/dev/null || echo 0) )) -lt "$AGE" ]; then
    cat "$CACHE"; exit 0
fi

raw=$(curl -fsS --max-time 8 "https://wttr.in/${enc}?format=j1" 2>/dev/null)
if [ -z "$raw" ]; then
    [ -f "$CACHE" ] && { cat "$CACHE"; exit 0; }
    printf '{"text":"","tooltip":"Sin conexión"}\n'; exit 0
fi

result=$(printf '%s\n' "$raw" | python3 -c '
import sys, json

ICONS = {
    "sunny": "", "clear": "", "partly": "",
    "cloud": "", "overcast": "󰖐",
    "rain": "", "drizzle": "", "shower": "",
    "snow": "", "blizzard": "", "sleet": "",
    "thunder": "", "lightning": "",
    "mist": "", "fog": "", "haze": "",
}

try:
    d = json.load(sys.stdin)
    c = d["current_condition"][0]
    n = d["nearest_area"][0]
    temp = c["temp_C"]
    feel = c["FeelsLikeC"]
    hum  = c["humidity"]
    desc = c["weatherDesc"][0]["value"]
    loc  = n["areaName"][0]["value"] + ", " + n["country"][0]["value"]
    icon = next((v for k, v in ICONS.items() if k in desc.lower()), "")
    print(json.dumps({
        "text":    f"{icon} {temp}°",
        "tooltip": f"{loc}\n{desc} · Sensación {feel}° · Humedad {hum}%",
    }))
except Exception as e:
    print(json.dumps({"text": "", "tooltip": f"Error: {e}"}))
')

printf '%s\n' "$result" | tee "$CACHE"
