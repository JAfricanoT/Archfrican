#!/usr/bin/env bash
# archfrican-vm-windows — guided Windows VM creation, pre-configured to dodge the classic KVM/QEMU
# gotcha: the virtio-win driver ISO MUST be on a SATA bus, never VirtIO — a VirtIO CD-ROM needs the
# VirtIO driver to even be read, which is exactly the driver you're trying to load FROM it (the "I
# can see the folder but the files inside are empty" symptom). Also wires up what Windows 11
# actually requires (UEFI + TPM 2.0) that a bare virt-install/virt-manager default doesn't always
# get right. The VM's own disk still uses VirtIO (best performance) — Windows Setup can load THAT
# driver too, from the same correctly-SATA-attached virtio-win ISO, once it can read it at all.
# Needs modules/67-virtualization.sh already applied — install via archfrican-defaults →
# "Máquinas virtuales" first if `virt-install`/virtio-win aren't there yet.
set -euo pipefail
source "$(dirname "$0")/../lib/archfrican-common.sh"

VIRTIO_ISO="/var/lib/libvirt/images/virtio-win.iso"

have virt-install || { note "instala virtualización primero: archfrican-defaults → Máquinas virtuales"; exit 1; }
[ -f "$VIRTIO_ISO" ] || { note "falta $VIRTIO_ISO — instala virtualización primero (incluye virtio-win)"; exit 1; }

# usermod -aG libvirt (done by modules/67-virtualization.sh) only takes effect in a NEW login
# session — a process already running (this very terminal) won't see it until logout/login. Rather
# than just warning and letting virt-install fail to connect, re-exec ourselves under the group via
# `sg` (works immediately, no relogin needed) so the tool "just works" right after install.
case " $(id -nG) " in
  *" libvirt "*) ;;
  *)
    note "grupo libvirt no activo en esta sesión todavía — reiniciando con 'sg libvirt' para que funcione sin desloguear"
    exec sg libvirt -c "$(printf '%q' "$0")"
    ;;
esac

os_sel="$(printf 'Windows 11\nWindows 10\nWindows Server 2022\nWindows Server 2019\n' \
    | fuzzel --dmenu --prompt '  versión de Windows  ')" || exit 0
case "$os_sel" in
  "Windows 11")          osv=win11 ;;
  "Windows 10")          osv=win10 ;;
  "Windows Server 2022") osv=win2k22 ;;
  "Windows Server 2019") osv=win2k19 ;;
  *) exit 0 ;;
esac

name="$(fuzzel --dmenu --prompt-only='  nombre de la VM  ')" || exit 0
[ -n "$name" ] || exit 0
if virsh -c qemu:///system dominfo "$name" >/dev/null 2>&1; then
  note "ya existe una VM llamada '$name'"; exit 1
fi

iso="$(fuzzel --dmenu --prompt-only='  ruta al ISO de Windows (ej: /home/user/Descargas/Win11.iso)  ')" || exit 0
iso="${iso/#\~/$HOME}"
if [ ! -f "$iso" ]; then
  # No ISO yet — instead of dying silently on a notification easy to miss, send you straight to
  # Microsoft's own official download page for the version you picked (per-OS: consumer media-
  # creation page for 10/11, eval center for Server, since Server ISOs are trial downloads there).
  case "$osv" in
    win11)   dl_url="https://www.microsoft.com/en-us/software-download/windows11" ;;
    win10)   dl_url="https://www.microsoft.com/en-us/software-download/windows10" ;;
    win2k22) dl_url="https://www.microsoft.com/en-us/evalcenter/evaluate-windows-server-2022" ;;
    win2k19) dl_url="https://www.microsoft.com/en-us/evalcenter/evaluate-windows-server-2019" ;;
  esac
  note "no encontré '$iso' — abriendo la página oficial de descarga. Bajalo y volvé a correr archfrican-vm-windows."
  have xdg-open && xdg-open "$dl_url" >/dev/null 2>&1 &
  exit 1
fi

mem="$(fuzzel --dmenu --prompt-only='  RAM en MB (enter = 4096)  ')" || exit 0
mem="${mem:-4096}"
disk="$(fuzzel --dmenu --prompt-only='  disco en GB (enter = 60)  ')" || exit 0
disk="${disk:-60}"
vcpus="$(fuzzel --dmenu --prompt-only='  vCPUs (enter = 2)  ')" || exit 0
vcpus="${vcpus:-2}"

# qemu:///system's sandboxed 'libvirt-qemu' user can't read files under your home directory by
# default (0700 perms) — copy the ISO into libvirt's own pool instead of fighting permissions,
# same reasoning already documented in modules/67-virtualization.sh for the virtio-win ISO itself.
pool_iso="/var/lib/libvirt/images/$(basename "$iso")"

ghostty -e sh -c "
  set -e
  if [ ! -f '$pool_iso' ]; then
    echo 'Copiando el ISO de Windows al pool de libvirt (puede tardar varios minutos)...'
    sudo cp '$iso' '$pool_iso'
    sudo chmod 644 '$pool_iso'
  fi
  virt-install \
    --connect qemu:///system \
    --name '$name' \
    --memory '$mem' \
    --vcpus '$vcpus' \
    --disk size='$disk',bus=virtio \
    --cdrom '$pool_iso' \
    --disk path='$VIRTIO_ISO',device=cdrom,bus=sata \
    --os-variant '$osv' \
    --tpm default \
    --boot uefi \
    --graphics spice
  printf '\n(enter para cerrar) '; read -r _
"

note "VM '$name' creada. Si Windows no detecta la red durante el setup: Load driver -> segundo CD-ROM (virtio-win) -> NetKVM\\$osv\\amd64"
