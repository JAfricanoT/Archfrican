#!/usr/bin/env bash
# TPM2 auto-unlock for your encrypted disk (FileVault-style) — OPT-IN, SAFE BY DESIGN. Enrolls the TPM2
# so boot CAN unlock LUKS without the passphrase. systemd-cryptenroll only ADDS a keyslot — your
# passphrase ALWAYS still works (at the LUKS prompt, press Enter to skip the TPM and type it). It backs
# up the LUKS header and offers an offline recovery key first. The boot-critical "make it unlock at
# boot" step (initramfs) is PRINTED for you to apply — not auto-run — and only works with the systemd
# 'sd-encrypt' hook. Validate a reboot immediately, while the passphrase fallback is in hand.
set -euo pipefail
have() { command -v "$1" >/dev/null 2>&1; }
note() { have notify-send && notify-send "Archfrican" "$1" || echo "$1"; }

have systemd-cryptenroll || { note "systemd-cryptenroll no disponible"; exit 1; }
pacman -Q tpm2-tss >/dev/null 2>&1 || sudo pacman -S --needed --noconfirm tpm2-tss >/dev/null 2>&1 || true
systemd-cryptenroll --tpm2-device=list 2>/dev/null | grep -q . || { note "no se detecta un TPM2 — abortando"; exit 1; }

dev="$(lsblk -rno NAME,FSTYPE | awk '$2=="crypto_LUKS"{print "/dev/"$1; exit}')"
[ -n "$dev" ] || { note "no encuentro una partición LUKS — abortando"; exit 1; }
uuid="$(sudo blkid -s UUID -o value "$dev" 2>/dev/null || true)"
mapname="$(lsblk -rno NAME,TYPE | awk '$2=="crypt"{print $1; exit}')"; mapname="${mapname:-root}"
sudo cryptsetup luksDump "$dev" 2>/dev/null | grep -qiE 'version:[[:space:]]*2' || { note "$dev no es LUKS2 — abortando"; exit 1; }

# TPM auto-unlock is only strong WITH Secure Boot — without it, PCR 7 alone is weak (an attacker with
# physical access could coax the TPM to release the key). Warn, don't block (the passphrase keyslot is
# untouched either way).
if ! bootctl status 2>/dev/null | grep -qiE 'secure boot:[[:space:]]*enabled'; then
  note "Aviso: Secure Boot NO está activo — el auto-unlock por TPM es DÉBIL sin él. Corre 'archfrican-secureboot' y actívalo antes (tu passphrase sigue funcionando igual)."
fi
confirm="$(printf 'Sí, enrolar TPM2 (mi passphrase seguirá funcionando)\nCancelar\n' | fuzzel --dmenu --prompt "  TPM2 en $dev  ")" || exit 0
case "$confirm" in "Sí,"*) ;; *) exit 0 ;; esac

target="/dev/disk/by-uuid/$uuid"; [ -n "$uuid" ] || target="$dev"
ghostty -e sh -c "set -e
echo '== Respaldo del header LUKS (cópialo luego a un USB) =='
sudo cryptsetup luksHeaderBackup '$target' --header-backup-file \"\$HOME/luks-header-backup.img\" 2>/dev/null && echo 'guardado en ~/luks-header-backup.img' || true
echo; echo '== Clave de recuperación offline (recomendado — guárdala en papel/USB) =='
printf '¿Enrolar una clave de recuperación primero? [Y/n] '; read -r a; [ \"\$a\" = n ] || sudo systemd-cryptenroll '$target' --recovery-key || true
echo; echo '== Enrolando el TPM2 (binding a PCR 7) — tu passphrase NO se modifica =='
sudo systemd-cryptenroll --tpm2-device=auto --tpm2-pcrs=7 '$target'
echo; echo '== Verificación (debe aparecer un token systemd-tpm2) =='; sudo cryptsetup luksDump '$target' | grep -i tpm2 || true
echo; printf '(enter para cerrar) '; read -r _"

if grep -qE '^HOOKS=.*\bsd-encrypt\b' /etc/mkinitcpio.conf 2>/dev/null; then
  note "TPM2 enrolado. Para que el arranque lo use, añade a /etc/crypttab.initramfs:  $mapname UUID=$uuid none tpm2-device=auto,tpm2-measure-pcr=yes   luego:  sudo mkinitcpio -P   y reinicia (si el TPM no abre, usa tu passphrase)."
else
  note "TPM2 enrolado ✓ — pero tu initramfs usa el hook 'encrypt' (no 'sd-encrypt'), así que el arranque seguirá pidiendo la passphrase. Migrar ese hook es un cambio de arranque sensible: hazlo manualmente y valida en VM."
fi
