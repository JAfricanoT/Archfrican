#!/usr/bin/env bash
# archfrican-keys — a live, never-drifting keyboard cheatsheet. Reads the niri
# config that is ACTUALLY applied (so it can't go stale) plus the keyd ⌘→Ctrl
# map, and shows everything in a fuzzel picker. Read-only: selecting just closes.
set -euo pipefail
cfg="${XDG_CONFIG_HOME:-$HOME/.config}/niri/config.kdl"
keyd="/etc/keyd/default.conf"

tsv() {
  if [ -r "$cfg" ]; then
    awk '
      /^[[:space:]]*\/\/[[:space:]]*nota:/ { next }
      /^[[:space:]]*\/\// && $0 !~ /\{/ {
        h = $0
        sub(/^[[:space:]]*\/\/[[:space:]]*/, "", h)
        pending = h
        next
      }
      /^[[:space:]]*(Mod|Print|XF86)[A-Za-z0-9+]*[[:space:]]*\{/ {
        line = $0
        key = line; sub(/[[:space:]]*\{.*/, "", key); gsub(/^[[:space:]]+/, "", key)
        if (line ~ /\/\//) { desc = line; sub(/.*\/\/[[:space:]]*/, "", desc) }
        else { desc = line; sub(/^[^{]*\{[[:space:]]*/, "", desc); sub(/[[:space:]]*;?[[:space:]]*\}.*/, "", desc) }
        gsub(/Mod/, "⌘", key)
        printf "%s\t%s\t%s\n", key, pending, desc
      }' "$cfg"
  fi
  if [ -r "$keyd" ]; then
    printf '\n'
    awk '
      /^\[.*\]/ { insec = ($0 == "[meta]"); next }
      insec && /^[a-z]+[[:space:]]*=/ {
        gsub(/[[:space:]]/, "")
        n = index($0, "="); k = substr($0, 1, n - 1); v = substr($0, n + 1)
        sub(/^C-/, "", v)
        printf "⌘+%s%s\tCtrl+%s\n", toupper(substr(k, 1, 1)), substr(k, 2), toupper(v)
      }' "$keyd"
  fi
}

if [ "${1:-}" = "__tsv" ]; then
  tsv
  exit 0
fi

if command -v walker >/dev/null 2>&1 \
   && elephant listproviders 2>/dev/null | grep -q "^desktopapplications$"; then
  exec walker -m "menus:keys"
fi

emit() {
  if [ -r "$cfg" ]; then
    # Each niri bind lives on one line: "Keys { action; }   // human comment".
    # Category headers are standalone comment lines (e.g. "// Lanzadores y núcleo")
    # that precede a run of bind lines. A comment line starting with "// nota:" is
    # implementation rationale, not a header — it's skipped and the previous
    # pending header (if any) stays in effect. Blank lines don't reset it either.
    awk '
      /^[[:space:]]*\/\/[[:space:]]*nota:/ { next }
      /^[[:space:]]*\/\// && $0 !~ /\{/ {
        h = $0
        sub(/^[[:space:]]*\/\/[[:space:]]*/, "", h)
        pending = h
        next
      }
      /^[[:space:]]*(Mod|Print|XF86)[A-Za-z0-9+]*[[:space:]]*\{/ {
        if (pending != "" && pending != printed) {
          printf "\n  ── %s ──\n", pending
          printed = pending
        }
        line = $0
        key = line; sub(/[[:space:]]*\{.*/, "", key); gsub(/^[[:space:]]+/, "", key)
        if (line ~ /\/\//) { desc = line; sub(/.*\/\/[[:space:]]*/, "", desc) }
        else { desc = line; sub(/^[^{]*\{[[:space:]]*/, "", desc); sub(/[[:space:]]*;?[[:space:]]*\}.*/, "", desc) }
        gsub(/Mod/, "⌘", key)
        printf "  %-26s  %s\n", key, desc
      }' "$cfg"
  fi
  if [ -r "$keyd" ]; then
    printf '\n  ── macOS ⌘ (keyd) ──\n'
    # keyd uses ini-style layers ("[meta]" then bare "c = C-c" lines), not "meta.c = C-c".
    # Only the [meta] layer is shown here (⌘+letter -> Ctrl+letter app shortcuts); [meta+shift]
    # is the WM pass-through already covered, with descriptions, by the niri binds above.
    awk '
      /^\[.*\]/ { insec = ($0 == "[meta]"); next }
      insec && /^[a-z]+[[:space:]]*=/ {
        gsub(/[[:space:]]/, "")
        n = index($0, "="); k = substr($0, 1, n - 1); v = substr($0, n + 1)
        sub(/^C-/, "", v)
        printf "  ⌘+%s%s  →  Ctrl+%s\n", toupper(substr(k, 1, 1)), substr(k, 2), toupper(v)
      }' "$keyd"
  fi
}

emit | fuzzel --dmenu --prompt "  atajos  " >/dev/null 2>&1 || true
