#!/usr/bin/env bash
# Wallpaper-driven dynamic theming (Material You) — pick an image, set it as the wallpaper, and re-tint
# the WHOLE shell from its colors. Opt-in; the curated themes stay the default (theme-switch <name>).
# The generated palette lives in user state (~/.config/archfrican), NOT in themes/, so it never causes
# convergence drift.
set -euo pipefail
have() { command -v "$1" >/dev/null 2>&1; }
note() { have notify-send && notify-send "Archfrican" "$1" || echo "$1"; }
have matugen || { note "instala matugen"; exit 1; }
have jq || { note "instala jq"; exit 1; }

img="${1:-}"
[ -n "$img" ] || img="$(fuzzel --dmenu --prompt 'ruta de la imagen:  ' </dev/null)" || exit 0
[ -r "$img" ] || { note "no existe la imagen: $img"; exit 1; }

if have awww; then awww img "$img" >/dev/null 2>&1 || true; fi
# Persist the path so archfrican-wallpaper-restore can repose it at next login (awww doesn't).
mkdir -p "$HOME/.config/archfrican"; printf '%s\n' "$img" > "$HOME/.config/archfrican/wallpaper"

json="$(matugen image "$img" --json hex 2>/dev/null)" || { note "matugen falló"; exit 1; }
# Defensive against matugen JSON format changes: try a few plausible paths, fall back to macOS-dark.
hex() { printf '%s' "$json" | jq -r "(.colors.dark.\"$1\" // .colors.\"$1\".default.hex // .colors.dark.\"$1\".hex // \"$2\")" 2>/dev/null; }
BG="$(hex background '#1c1c1e')";          FG="$(hex on_background '#f5f5f7')";        ACCENT="$(hex primary '#0a84ff')"
BG_ALT="$(hex surface_container '#2c2c2e')"; BG_DIM="$(hex surface_variant '#3a3a3c')"; FG_DIM="$(hex on_surface_variant '#8e8e93')"

out="$HOME/.config/archfrican/dynamic-colors.sh"; mkdir -p "$(dirname "$out")"
cat > "$out" <<EOF
# Generated by archfrican-wallpaper (matugen Material You). Source image: $img
export GTK_SCHEME="prefer-dark"; export GTK_THEME="WhiteSur-Dark"; export ICON_THEME="WhiteSur-dark"
export BG="$BG" BG_ALT="$BG_ALT" BG_DIM="$BG_DIM"
export FG="$FG" FG_DIM="$FG_DIM"
export ACCENT="$ACCENT"
export RED="#ff5555" GREEN="#50fa7b" YELLOW="#f1fa8c" BLUE="#8be9fd" MAGENTA="#ff79c6" CYAN="#80ffea"
export BORDER_ACTIVE="$ACCENT" BORDER_INACTIVE="$BG_DIM"
EOF
theme-switch dynamic && note "tema dinámico aplicado desde el wallpaper"
