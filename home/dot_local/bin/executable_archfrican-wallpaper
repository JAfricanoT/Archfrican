#!/usr/bin/env bash
# Wallpaper-driven dynamic theming (Material You) — pick an image, set it as the wallpaper, and re-tint
# the WHOLE shell from its colors. Opt-in; the curated themes stay the default (theme-switch <name>).
# The generated palette lives in user state (~/.config/archfrican), NOT in themes/, so it never causes
# convergence drift.
set -euo pipefail
source "$(dirname "$0")/../lib/archfrican-common.sh"
have matugen || { note "instala matugen"; exit 1; }
have jq || { note "instala jq"; exit 1; }

img="${1:-}"
if [ -z "$img" ]; then
  # A real picker, not a blind "type a path": fuzzel.ini sets exit-immediately-if-empty=yes
  # (for archfrican-spotlight), which ALSO makes an empty-stdin dmenu close instantly with no
  # UI at all, `--prompt-only` included — there's no CLI override for that ini setting, so this
  # sidesteps it by giving the picker real content instead of fighting it. Scans common
  # wallpaper spots for images the user can actually browse/fuzzy-search.
  pics="$(xdg-user-dir PICTURES 2>/dev/null)"; dls="$(xdg-user-dir DOWNLOAD 2>/dev/null)"
  candidates=()
  # while+read, not `arr=($(find ...))`: filenames with spaces (e.g. "Screenshot from ....png",
  # common under Pictures/Screenshots) would otherwise get word-split into several bogus entries.
  # Same reasoning as read_pkg_list in lib/common.sh.
  while IFS= read -r f; do candidates+=("$f"); done < <(
    find "$pics" "$dls" /usr/share/backgrounds "$HOME/.local/share/backgrounds" \
      -maxdepth 3 -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \) \
      2>/dev/null | sort -u)
  [ "${#candidates[@]}" -gt 0 ] || { note "no se encontraron imágenes en $pics, $dls o /usr/share/backgrounds"; exit 1; }
  # Walker's own dmenu frontend (not a native elephant menu — out of scope per
  # docs/superpowers/specs/2026-07-02-walker-menu-integration-design.md, since this list is
  # filesystem-dependent, not a fixed menu), so this LOOKS like the rest of the launcher instead
  # of a separate fuzzel popup. Same stdin-list/stdout-selection contract as fuzzel --dmenu.
  # Falls back to fuzzel if walker/elephant aren't responding, so this never goes fully dark.
  if walker_native; then
    img="$(printf '%s\n' "${candidates[@]}" | walker --dmenu --placeholder 'fondo de pantalla:')" || exit 0
  else
    img="$(printf '%s\n' "${candidates[@]}" | fuzzel --dmenu --prompt 'fondo de pantalla:  ')" || exit 0
  fi
fi
[ -r "$img" ] || { note "no existe la imagen: $img"; exit 1; }

if have awww; then awww img "$img" >/dev/null 2>&1 || true; fi
# Persist the path so archfrican-wallpaper-restore can repose it at next login (awww doesn't).
mkdir -p "$HOME/.config/archfrican"; printf '%s\n' "$img" > "$HOME/.config/archfrican/wallpaper"

# --prefer is REQUIRED for a non-interactive invocation (spawned from a keybind, no controlling
# terminal): without it, matugen aborts asking which of several extracted source colors to prefer
# whenever a photo yields more than one candidate — which is the common case for any real photo.
json="$(matugen image "$img" --json hex --prefer saturation 2>/dev/null)" || { note "matugen falló"; exit 1; }
# Defensive against matugen JSON format changes: try a few plausible paths, fall back to macOS-dark.
hex() { printf '%s' "$json" | jq -r "(.colors.dark.\"$1\" // .colors.\"$1\".default.hex // .colors.dark.\"$1\".hex // \"$2\")" 2>/dev/null; }
BG="$(hex background '#1c1c1e')";          FG="$(hex on_background '#f5f5f7')";        ACCENT="$(hex primary '#0a84ff')"
BG_ALT="$(hex surface_container '#2c2c2e')"; BG_DIM="$(hex surface_variant '#3a3a3c')"; FG_DIM="$(hex on_surface_variant '#8e8e93')"

out="$HOME/.config/archfrican/dynamic-colors.sh"; mkdir -p "$(dirname "$out")"
cat > "$out" <<EOF
# Generated by archfrican-wallpaper (matugen Material You). Source image: $img
export GTK_SCHEME="prefer-dark"; export GTK_THEME="WhiteSur-Dark"; export ICON_THEME="WhiteSur-dark"
export BG="$BG" BG_ALT="$BG_ALT" BG_DIM="$BG_DIM"
export FG="$FG" FG_DIM="$FG_DIM"
export ACCENT="$ACCENT"
export RED="#ff5555" GREEN="#50fa7b" YELLOW="#f1fa8c" BLUE="#8be9fd" MAGENTA="#ff79c6" CYAN="#80ffea"
export BORDER_ACTIVE="$ACCENT" BORDER_INACTIVE="$BG_DIM"
EOF
theme-switch dynamic && note "tema dinámico aplicado desde el wallpaper"
