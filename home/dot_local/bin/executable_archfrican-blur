#!/usr/bin/env bash
# Safely enable/disable niri's frosted-glass blur — on BOTH windows (window-rule) AND the launcher +
# control center / notifications (layer-rule). Guards with `niri validate` and REVERTS if your niri is
# too old to understand the directives, so it can never leave you with a config niri won't start. niri
# live-reloads on save.
set -euo pipefail
cfg="${XDG_CONFIG_HOME:-$HOME/.config}/niri/config.kdl"
[ -r "$cfg" ] || { echo "no niri config at $cfg" >&2; exit 1; }

# window-rule blur block (4-space indent — it lives inside window-rule { … }).
win_on=$'    blur {\n        on\n        passes 3\n        radius 8\n    }'
win_off=$'    // blur {\n    //     on\n    //     passes 3\n    //     radius 8\n    // }'

# Top-level layer-rule blur+shadow, one per frosted layer surface. Multi-line on purpose: single-line
# nested KDL silently breaks niri. Corner radii match the launcher/control-center (16) + the toast (12).
layer_blocks() {
  cat <<'KDL'
layer-rule {
    match namespace="^launcher$"
    geometry-corner-radius 16
    blur {
        on
        passes 3
        radius 8
    }
    shadow {
        on
        softness 30
        spread 3
        offset x=0 y=6
        color "#00000055"
    }
}
layer-rule {
    match namespace="^swaync-control-center$"
    geometry-corner-radius 16
    blur {
        on
        passes 3
        radius 8
    }
    shadow {
        on
        softness 30
        spread 3
        offset x=0 y=6
        color "#00000055"
    }
}
layer-rule {
    match namespace="^swaync-notification-window$"
    geometry-corner-radius 12
    blur {
        on
        passes 3
        radius 8
    }
    shadow {
        on
        softness 30
        spread 3
        offset x=0 y=6
        color "#00000055"
    }
}
KDL
}
layer_on="$(layer_blocks)"
layer_off="$(layer_blocks | sed 's,^,// ,')"

# splice <start> <end> <repl-file> <in-file> — print <in-file> with the region BETWEEN the markers
# replaced by <repl-file>'s contents (the markers themselves preserved). The block is read from a FILE
# (not an awk -v string) so multi-line replacements are portable across awk variants — the same NR==FNR
# trick theme-switch uses for the niri splice. index() is a substring test (not regex), so "// BLUR-START"
# never matches "// LAYER-BLUR-START" — the two regions stay independent.
splice() {
  awk -v s="$1" -v e="$2" '
    NR==FNR      { blk = blk $0 ORS; next }
    index($0, s) { print; printf "%s", blk; skip=1; next }
    index($0, e) { skip=0 }
    !skip        { print }
  ' "$3" "$4"
}

set_blur() {   # set_blur <on|off> — print the rewritten config (both regions)
  local wb lb t
  if [ "$1" = on ]; then wb="$win_on"; lb="$layer_on"; else wb="$win_off"; lb="$layer_off"; fi
  t="$(mktemp)"
  splice '// BLUR-START' '// BLUR-END' <(printf '%s\n' "$wb") "$cfg" > "$t"
  splice '// LAYER-BLUR-START' '// LAYER-BLUR-END' <(printf '%s\n' "$lb") "$t"
  rm -f "$t"
}

case "${1:-status}" in
  on|off)
    grep -q 'BLUR-START' "$cfg" || { echo "no blur markers in $cfg (re-apply the niri dotfile)" >&2; exit 1; }
    cp "$cfg" "$cfg.afbak"
    if set_blur "$1" > "$cfg.new"; then
      mv "$cfg.new" "$cfg"
    else
      rm -f "$cfg.new"; mv "$cfg.afbak" "$cfg"; echo "blur: rewrite failed — no change." >&2; exit 1
    fi
    if [ "$1" = on ] && command -v niri >/dev/null 2>&1 && ! niri validate >/dev/null 2>&1; then
      mv "$cfg.afbak" "$cfg"; echo "your niri rejected blur (likely too old) — reverted, no change." >&2; exit 1
    fi
    rm -f "$cfg.afbak"; echo "blur: $1 (windows + launcher/control-center; niri live-reloads on save)" ;;
  status)
    if awk '/BLUR-START/{f=1;next}/BLUR-END/{f=0}f' "$cfg" | grep -qE '^[[:space:]]*blur[[:space:]]*\{'; then
      echo on; else echo off; fi ;;
  *)
    echo "usage: archfrican-blur on|off|status" >&2; exit 1 ;;
esac
