#!/usr/bin/env bash
# Toggle the Orca screen reader. niri (>=25.08) is the only tiling Wayland compositor that exposes its
# UI via AccessKit + the keyboard-grab interface Orca needs, so the screen reader actually works here —
# best-in-class FOSS tiling accessibility that Hyprland setups cannot offer.
set -euo pipefail
note() { if command -v notify-send >/dev/null 2>&1; then notify-send "Archfrican" "$1" || true; fi; }
if pgrep -x orca >/dev/null 2>&1; then
  pkill -x orca 2>/dev/null || true
  note "Lector de pantalla: OFF"
else
  command -v orca >/dev/null 2>&1 || { note "instala orca"; exit 1; }
  setsid orca >/dev/null 2>&1 &
  note "Lector de pantalla: ON"
fi
