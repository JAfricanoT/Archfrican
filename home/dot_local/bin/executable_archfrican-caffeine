#!/usr/bin/env bash
# archfrican-caffeine — idle-inhibitor toggle (waybar custom/caffeine module)
# ON:  swayidle stopped → screen never auto-locks or auto-suspends
# OFF: archfrican-idle restarted → normal lock/sleep policy restored
# Uses SIGRTMIN+8 so waybar refreshes the icon instantly on click.
STAMP=/tmp/archfrican-caffeine
IDLE="$HOME/.local/bin/archfrican-idle"
# Nerd Font glyphs: U+F186 = moon (off), U+F0F4 = coffee (on) — both nf-fa, same visual weight
ICON_OFF=$'\xef\x86\x86'   # nf-fa-moon-o  U+F186
ICON_ON=$'\xef\x83\xb4'    # nf-fa-coffee  U+F0F4

if [ "$1" = toggle ]; then
    if [ -f "$STAMP" ]; then
        rm -f "$STAMP"
        pgrep -x swayidle >/dev/null 2>&1 || setsid -f "$IDLE"
    else
        touch "$STAMP"
        pkill -x swayidle 2>/dev/null || true
    fi
    pkill -SIGRTMIN+8 waybar 2>/dev/null || true
    exit 0
fi

if [ -f "$STAMP" ]; then
    printf '{"text":"%s","class":"active","tooltip":"Caffeine ON — pantalla siempre activa"}\n' "$ICON_ON"
else
    printf '{"text":"%s","class":"","tooltip":"Caffeine — clic para inhibir el apagado de pantalla"}\n' "$ICON_OFF"
fi
