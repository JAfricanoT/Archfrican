#!/usr/bin/env bash
# Shown ONCE per user on first desktop login (stamp-gated): a friendly, clickable
# welcome that teaches the few Archfrican-specific keys and offers to check updates.
# Spawned by niri at startup. Omarchy's lesson: two good notifications beat a wizard.
set -euo pipefail
state="${XDG_STATE_HOME:-$HOME/.local/state}/archfrican"
stamp="$state/welcome-shown"
[ -e "$stamp" ] && exit 0
command -v notify-send >/dev/null 2>&1 || exit 0
mkdir -p "$state"
sleep 4   # let the notification daemon (swaync) and the bar come up first

act="$(notify-send --app-name="Archfrican" -t 25000 \
  --action="tour=Ver el tour" --action="update=Buscar actualizaciones" \
  "Bienvenido a Archfrican" \
  "⌘+Space abre el launcher · ⌘+Shift+V el historial del portapapeles · ⌘+Shift+K muestra todos los atajos · escribe 'theme-switch' para cambiar el tema." 2>/dev/null)" || true

: > "$stamp"   # show only once, even if the daemon wasn't ready

case "$act" in
  tour)   exec "$HOME/.local/bin/archfrican-welcome" --tour ;;
  update) exec ghostty -e archfrican-update ;;
esac
