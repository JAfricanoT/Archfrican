#!/usr/bin/env bash
# archfrican-actions — the command surface / "control center in the launcher".
# One fuzzel menu that reaches every Archfrican action and every launcher mode,
# the way Spotlight Actions / omarchy-menu / a KRunner do. Each item is a named
# verb (same spirit as the bin/ tools), so the keyboard-driven system stays
# discoverable instead of memorized.
#
# The fuzzel fallback reads menus/actions.toml directly (toml_menu_list/toml_menu_action,
# lib/archfrican-common.sh) instead of hand-duplicating its entries — one file is the source
# of truth for both the native Walker menu and this fallback, so they can't drift apart.
set -euo pipefail
source "$(dirname "$0")/../lib/archfrican-common.sh"
MENUS="${XDG_CONFIG_HOME:-$HOME/.config}/elephant/menus"

# Native menu (menus/actions.toml) when Walker/elephant are up; fuzzel fallback below otherwise.
if command -v walker >/dev/null 2>&1 \
   && elephant listproviders 2>/dev/null | grep -q "^desktopapplications$"; then
  exec walker -m "menus:actions"
fi

have fuzzel  || { note "fuzzel no está instalado"; exit 1; }
have python3 || { note "falta python3"; exit 1; }

# "Cambiar tema…" is backed by a Lua provider (menus/themes.lua), not a static .toml — it discovers
# themes by listing ~/.archfrican/themes/*/ live, so the fallback replicates that directly instead
# of trying to read a themes.toml that doesn't exist.
pick_theme() {
  local t
  t="$(for d in "$HOME"/.archfrican/themes/*/; do [ -d "$d" ] && basename "$d"; done \
      | fuzzel --dmenu --prompt '  tema  ')" && [ -n "$t" ] && theme-switch "$t"
}

# run_toml_menu <file.toml> <prompt> — list its entries in fuzzel; run (or open in a terminal) the
# chosen one, or recurse into its submenu (another sibling .toml, or the one special-cased Lua menu).
run_toml_menu() {
  local file="$1" prompt="$2" sel line kind value
  [ -r "$file" ] || { note "no encuentro $(basename "$file")"; return 1; }
  sel="$(toml_menu_list "$file" | fuzzel --dmenu --prompt "$prompt")" || return 0
  [ -n "$sel" ] || return 0
  line="$(toml_menu_action "$file" "$sel")"
  [ -n "$line" ] || return 0
  kind="${line%%$'\t'*}"; value="${line#*$'\t'}"
  case "$kind" in
    run)      sh -c "$value" ;;
    terminal) ghostty -e sh -c "$value" ;;
    submenu)
      case "$value" in
        themes) pick_theme ;;
        *)      run_toml_menu "$MENUS/$value.toml" "  $value  " ;;
      esac ;;
  esac
}

run_toml_menu "$MENUS/actions.toml" "  acciones  "
