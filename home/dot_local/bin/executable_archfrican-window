#!/usr/bin/env bash
# Window switcher (an Alt-Tab over ALL windows) — lists every niri window and
# focuses the chosen one. Pure niri IPC, no plugins.
set -euo pipefail
command -v niri >/dev/null 2>&1 || exit 1
command -v jq >/dev/null 2>&1 || exit 1
tab="$(printf '\t')"
# ── WM seam (niri): all compositor IPC in this file routes through here — one place to port. docs/WM-INTEGRATION.md
wm_windows_json() { niri msg --json windows; }
wm_focus_window() { niri msg action focus-window --id "$1"; }

line="$(wm_windows_json \
  | jq -r '.[] | "\(.id)\t\(.app_id // "app")  ·  \(.title // "")"' \
  | sort -t "$tab" -k2 \
  | fuzzel --dmenu --prompt '  ventanas  ')" || exit 0
id="${line%%"$tab"*}"
[ -n "$id" ] || exit 0
wm_focus_window "$id"
