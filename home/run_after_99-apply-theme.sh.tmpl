#!/usr/bin/env bash
# chezmoi run_after: re-apply the saved Archfrican theme AFTER the dotfiles are
# deployed. This (1) splices the themed block into the niri config.kdl that
# chezmoi just wrote (theme-switch is skipped at install time because config.kdl
# doesn't exist yet), and (2) (re)generates the chezmoi-ignored color files so
# the user's chosen theme survives every `chezmoi apply` instead of reverting.
# Reads ~/.config/.archfrican-theme (written by theme-switch); defaults to adl-dark.
set -euo pipefail
ARCHFRICAN_ROOT="{{ .chezmoi.homeDir }}/.archfrican"

# Re-apply the saved monitor layout (archfrican-displays) so a nwg-displays arrangement survives
# `chezmoi apply` too — same rationale as the theme. Self-contained (only ~/.config); no-op if the user
# never ran `archfrican-displays save`, so it does nothing on a fresh install.
disp="$HOME/.local/bin/archfrican-displays"
if [ -x "$disp" ]; then "$disp" restore || true; fi

theme="$(cat "$HOME/.config/.archfrican-theme" 2>/dev/null || echo archfrican-dark)"
[ -x "$ARCHFRICAN_ROOT/bin/theme-switch" ] || exit 0   # repo clone absent: nothing to do
env ARCHFRICAN_ROOT="$ARCHFRICAN_ROOT" "$ARCHFRICAN_ROOT/bin/theme-switch" "$theme" \
  || echo "archfrican: theme re-apply failed for '$theme' (run: theme-switch $theme)" >&2

# Frosted glass: enable blur ONCE, the first time this runs (the default identity ships with it). The niri
# config.kdl now exists (theme-switch just spliced it), so archfrican-blur can validate with `niri validate`
# and auto-revert if niri is too old — this can never brick the config. Stamped so a later
# `archfrican-blur off` is respected: converge never forces it back on.
# Stamp name bumped from blur-default-done: the first cut shipped a wrong blur directive that always
# reverted, so existing installs must re-attempt once with the corrected syntax. Only stamp it 'done'
# when blur actually took (an older niri reverts) — otherwise retry on the next converge.
blur_stamp="${XDG_STATE_HOME:-$HOME/.local/state}/archfrican/glass-default-applied"
blur="$HOME/.local/bin/archfrican-blur"
if [ ! -e "$blur_stamp" ] && [ -x "$blur" ]; then
  mkdir -p "$(dirname "$blur_stamp")"
  "$blur" on >/dev/null 2>&1 || true
  if [ "$("$blur" status 2>/dev/null)" = on ]; then : > "$blur_stamp"; fi
fi

# Reinicia elephant para que detecte menús nuevos/editados bajo ~/.config/elephant/menus/ y
# ~/.config/elephant/lib/ — sin esto, un `chezmoi apply` que agregue o cambie un archivo de menú
# no se refleja hasta el próximo login. No falla el hook si elephant no está instalado (fresh
# install antes de que 20-niri-desktop.sh corra, o un perfil sin Walker).
if command -v elephant >/dev/null 2>&1; then
  pkill -x elephant 2>/dev/null || true
  sleep 0.5
  setsid -f elephant >/dev/null 2>&1 || true
fi
