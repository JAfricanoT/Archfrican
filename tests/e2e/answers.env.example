# Archfrican e2e autopilot answers — copy to answers.env and edit, OR export these before
# running tests/e2e/selftest.sh. They drive a NON-INTERACTIVE install that WIPES AF_AP_DISK.
#
#   AUTOMATED VM TESTING ONLY. Never source this on a real machine.
#
# answers.env is gitignored so test credentials never get committed.

AF_AP_DISK=             # the VM's disk; leave empty to auto-pick the single disk (lsblk: vda/sda/nvme0n1)
AF_AP_ENCRYPT=yes       # yes = LUKS2 on root (the path worth testing); no = unencrypted

AF_AP_HOST=archfrican-test
AF_AP_USER=archfrican
AF_AP_USER_PASSWORD=test1234        # the wheel user's password (throwaway)
AF_AP_LUKS_PASSPHRASE=test1234      # required when AF_AP_ENCRYPT=yes; you type this ONCE at first boot

AF_AP_TZ=UTC
AF_AP_LOCALE=en_US.UTF-8
AF_AP_XKB=us            # try 'latam' or 'es' to verify the keymap works at the LUKS prompt (check #3)
AF_AP_THEME=adl-dark
AF_AP_GPU=intel         # a safe default inside a VM

# AF_AP_REBOOT=1        # uncomment to auto-reboot after the pre-reboot assertions pass
